# Genre search mode: structured query against the discovery backend.

direction: down

input: "Genre search request" {
  shape: rectangle
  style.fill: "#d4edda"
}

parse: "Parse query syntax\n(genre list, type counts,\nvibe selector)" {
  shape: step
}

err_parse: "Query syntax error" {
  shape: rectangle
  style.fill: "#f8d7da"
}

err_no_key: "Backend not configured error" {
  shape: rectangle
  style.fill: "#f8d7da"
}

input -> parse
parse -> err_parse: "invalid syntax"
parse -> err_no_key: "backend unavailable"

batch: "Per-genre batch fetch\nin parallel" {
  shape: step
  style.fill: "#fff3cd"
}

parse -> batch: "valid"

interleave: "Interleave across genres\nand deduplicate" {
  shape: step
}

sample: "Sampling strategy" {
  shape: diamond
  style.fill: "#f5f5f5"
}

batch -> interleave -> sample

hot: "Vibe: hot\n(top-N or even-spaced)" {
  shape: rectangle
}

mixed: "Vibe: mixed\n(stratified across\ntop, middle, tail)" {
  shape: rectangle
}

sample -> hot: "popularity-leaning"
sample -> mixed: "discovery-leaning"

enrich: "Artwork enrichment\nfrom permanent cache" {
  shape: step
}

hot -> enrich
mixed -> enrich

response: "Genre-search payload\n(tracks, albums, artists\nplus parser warnings)" {
  shape: parallelogram
  style.fill: "#d4edda"
}

enrich -> response
