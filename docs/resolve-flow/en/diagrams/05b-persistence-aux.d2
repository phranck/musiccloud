# Persistence, part 2: external IDs, previews, alias, preview enrichment.

direction: down

input: "From canonical write" {
  shape: parallelogram
  style.fill: "#d4edda"
}

ext_ids: "Aggregate external identifiers\nacross every contacted service\n(idempotent insert)" {
  shape: step
  style.fill: "#fff3cd"
}

input -> ext_ids

per_link_preview: "Upsert preview URLs\nper cross-service link\nwith parsed expiry" {
  shape: step
  style.fill: "#fff3cd"
}

source_preview: "Upsert preview URL\nfrom the source service" {
  shape: step
  style.fill: "#fff3cd"
}

ext_ids -> per_link_preview
per_link_preview -> source_preview

alias: "Save short-link alias\n(when input was a short link\nthat got expanded)" {
  shape: step
  style.fill: "#fff3cd"
}

source_preview -> alias

deezer_check: "Preview refresh needed?\n(missing or expired,\ntrack has ISRC)" {
  shape: diamond
  style.fill: "#f5f5f5"
}

alias -> deezer_check

deezer_refresh: "Refresh preview\nfrom the most stable source" {
  shape: step
  style.fill: "#fff3cd"
}

deezer_check -> deezer_refresh: "yes"

result: "Persistence result\n(canonical id, share short-id,\nrefreshed preview URL)" {
  shape: parallelogram
  style.fill: "#cce5ff"
}

deezer_check -> result: "no"
deezer_refresh -> result

response_route: "Route layer:\nbuild user-facing\nresponse payload" {
  shape: parallelogram
}

response_crawler: "Crawler layer:\ncount as ingested" {
  shape: parallelogram
  style.fill: "#e2d4f0"
}

result -> response_route
result -> response_crawler
