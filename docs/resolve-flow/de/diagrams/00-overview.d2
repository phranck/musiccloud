# Dispatcher-Übersicht: welche Eingabeform geht in welchen Pfad?

direction: down

client: HTTP-Client {
  shape: person
}

post: "Authentifizierter Resolver-Endpunkt" {
  shape: hexagon
  style.fill: "#cce5ff"
}

get: "Unauthentifizierter Resolver-Endpunkt" {
  shape: hexagon
  style.fill: "#fff3cd"
}

client -> post: "mit Bearer-Token oder API-Key"
client -> get: "ohne Auth, anfragebegrenzt"

dispatcher: "Eingabeform erkennen" {
  shape: diamond
  style.fill: "#f5f5f5"
}

post -> dispatcher
get -> dispatcher

genre_browse: "Genre-Raster-Anfrage" {
  shape: rectangle
  style.fill: "#d4edda"
}
genre_search: "Genre-Such-Anfrage" {
  shape: rectangle
  style.fill: "#d4edda"
}
structured_search: "Strukturierte Suche" {
  shape: rectangle
  style.fill: "#fff3cd"
}
selected: "Disambiguierungs-Folgeanfrage\n(nur authentifiziert)" {
  shape: rectangle
  style.fill: "#f8d7da"
}
url_input: "Streaming-Dienst-URL" {
  shape: rectangle
  style.fill: "#cce5ff"
}
text_input: "Textsuche" {
  shape: rectangle
  style.fill: "#fff3cd"
}

dispatcher -> genre_browse: "Raster-Syntax"
dispatcher -> genre_search: "Such-Syntax"
dispatcher -> structured_search: "title:/artist:/album:"
dispatcher -> selected: "Kandidatenkennung"
dispatcher -> url_input: "als URL erkennbar"
dispatcher -> text_input: "sonst"

flow_genre: "Genre-Discovery-Schicht" {
  shape: cloud
  style.fill: "#d4edda"
}

flow_url: "URL-Auflösungs-Schicht" {
  shape: cloud
  style.fill: "#cce5ff"
}

flow_text: "Textsuch-Schicht" {
  shape: cloud
  style.fill: "#fff3cd"
}

genre_browse -> flow_genre
genre_search -> flow_genre
structured_search -> flow_text
selected -> flow_text
url_input -> flow_url
text_input -> flow_text

persist: "Persistenz-Schicht" {
  shape: cylinder
  style.fill: "#e2d4f0"
}

response_track: "Aufgelöste Entität\n(Track, Album, Interpret)" {
  shape: parallelogram
}

response_genre: "Discovery-Antwort\n(kein DB-Schreiben)" {
  shape: parallelogram
  style.fill: "#d4edda"
}

response_disambig: "Disambiguierungs-Antwort\n(kein DB-Schreiben)" {
  shape: parallelogram
  style.fill: "#fff3cd"
}

flow_url -> persist
flow_text -> persist: "hohe Konfidenz"
flow_text -> response_disambig: "mehrdeutig"
flow_genre -> response_genre
persist -> response_track
