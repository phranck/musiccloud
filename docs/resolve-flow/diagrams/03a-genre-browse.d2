# Genre-Raster: kuratiertes Tag-Raster mit Cover-Prüfung.

direction: down

input: "Genre-Raster-Anfrage" {
  shape: rectangle
  style.fill: "#d4edda"
}

cache: "Raster-Cache\n(24 Stunden im Speicher)" {
  shape: cylinder
  style.fill: "#fff8e1"
}

input -> cache

top_tags: "Beliebte Genre-Tags abrufen" {
  shape: step
}

filter: "Nicht-Genre-Tags filtern\n(Länder, Jahrzehnte,\nInstrumente, Sammlungen)" {
  shape: step
}

dedupe: "Schreibvarianten vereinheitlichen,\nsodass dasselbe Genre\nnicht mehrfach erscheint" {
  shape: step
}

cache -> top_tags: "Miss"
top_tags -> filter -> dedupe

probe: "Pro Kandidat Cover prüfen\nund leere Genres entfernen" {
  shape: step
}

dedupe -> probe

artwork_url: "Kachel-Cover wird bei Bedarf\nvon separatem Endpunkt geliefert" {
  shape: step
}

probe -> artwork_url: "Kachel hat Cover"

response: "Raster-Antwort" {
  shape: parallelogram
  style.fill: "#d4edda"
}

artwork_url -> response
cache -> response: "Treffer"
