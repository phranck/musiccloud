# Textsuche, Teil 1: erster Durchgang über aktive Adapter.

direction: down

input: "Textsuche-Anfrage" {
  shape: rectangle
  style.fill: "#fff3cd"
}

iterate: "Aktive Adapter durchlaufen" {
  shape: step
}

input -> iterate

has_candidates: "Adapter liefert\nKandidatenliste?" {
  shape: diamond
  style.fill: "#f5f5f5"
}

candidates_path: "Kandidatenlisten-Suche" {
  shape: rectangle
}

simple_path: "Einzelergebnis-Suche\n(Adapter-Notlösung)" {
  shape: rectangle
}

iterate -> has_candidates
has_candidates -> candidates_path: "ja"
has_candidates -> simple_path: "nein"

confidence_check: "Konfidenz des vordersten\nüber Auto-Auswahl-Schwelle?" {
  shape: diamond
  style.fill: "#f5f5f5"
}

candidates_path -> confidence_check

cache_isrc: "Cache-Suche per ISRC" {
  shape: cylinder
  style.fill: "#fff8e1"
}

cross: "Dienstübergreifende Suche" {
  shape: cloud
  style.fill: "#cce5ff"
}

resolved: "Aufgelöster Track" {
  shape: parallelogram
  style.fill: "#cce5ff"
}

simple_path -> cache_isrc: "Treffer gefunden,\nKonfidenz ok"
confidence_check -> cache_isrc: "ja (Auto-Auswahl)"

cache_isrc -> cross: "Miss"
cross -> resolved
cache_isrc -> resolved: "Treffer"

err_not_found: "Fehler: Track nicht gefunden" {
  shape: rectangle
  style.fill: "#f8d7da"
}

iterate -> err_not_found: "alle Adapter ausgeschöpft"

disambig_out: "Weiter zur Disambiguierung" {
  shape: parallelogram
  style.fill: "#fff3cd"
}

confidence_check -> disambig_out: "nein"
