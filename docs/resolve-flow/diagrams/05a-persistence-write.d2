# Persistenz, Teil 1: kanonisches Schreiben von Track-Eintrag, Links und Kurzlink.

direction: down

input: "Aufgelöster Track" {
  shape: rectangle
  style.fill: "#cce5ff"
}

persist: "Kanonischen Track-Eintrag schreiben\nmit dienstübergreifenden Links" {
  shape: step
  style.fill: "#cce5ff"
}

input -> persist

dedup: "Vorhandener Eintrag?\n(per ISRC oder Quell-URL)" {
  shape: diamond
  style.fill: "#f5f5f5"
}

persist -> dedup

update: "Metadaten am vorhandenen\nEintrag aktualisieren" {
  shape: rectangle
}

insert: "Neuen Track-Eintrag\nmit frischen Kennungen anlegen" {
  shape: rectangle
}

dedup -> update: "ja"
dedup -> insert: "nein"

upsert_links: "Dienstübergreifende Links per Upsert\n(idempotent über das Paar\nEintrag-und-Dienst)" {
  shape: rectangle
  style.fill: "#fff3cd"
}

update -> upsert_links
insert -> upsert_links

short_url: "Share-Kurzlink anlegen\n(nur bei neuem Track)" {
  shape: rectangle
}

upsert_links -> short_url

next: "Weiter zu Begleit-Schreibvorgängen" {
  shape: parallelogram
  style.fill: "#d4edda"
}

short_url -> next: "Transaktions-Commit"
