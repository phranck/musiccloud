# URL-Pfad, Teil 1: Cache-Stufen und Bestimmung des Quell-Dienstes.

direction: down

input: "URL-Eingabe" {
  shape: rectangle
  style.fill: "#cce5ff"
}

strip1: "Tracking-Parameter entfernen" {
  shape: step
}

expand: "Kurzlinks auflösen\nüber HTTP-Weiterleitungen" {
  shape: step
}

strip2: "Tracking-Parameter erneut entfernen\n(Kurzlink-Ziele fügen oft\nneue Parameter ein)" {
  shape: step
}

input -> strip1 -> expand -> strip2

cache_url: "Cache-Suche per kanonischer URL" {
  shape: cylinder
  style.fill: "#fff8e1"
}

cache_alias: "Cache-Suche per Kurzlink\n(nur bei aufgelöster URL)" {
  shape: cylinder
  style.fill: "#fff8e1"
}

strip2 -> cache_url
cache_url -> cache_alias: "Miss"

identify: "Quell-Dienst bestimmen\n(berücksichtigt Abschaltung)" {
  shape: diamond
  style.fill: "#f5f5f5"
}

err_disabled: "Fehler: Dienst abgeschaltet" {
  shape: rectangle
  style.fill: "#f8d7da"
}

err_unknown: "Fehler: kein Musik-Link" {
  shape: rectangle
  style.fill: "#f8d7da"
}

cache_alias -> identify: "Miss"
identify -> err_disabled: "erkannt, aber abgeschaltet"
identify -> err_unknown: "kein Adapter erkennt"

next: "Weiter zum Metadaten-Abruf" {
  shape: parallelogram
  style.fill: "#d4edda"
}

identify -> next: "aktiver Adapter gefunden"
cache_url -> next: "Treffer, dann Lücken füllen"
cache_alias -> next: "Treffer"
