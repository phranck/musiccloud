# Dienstübergreifende Suche: jeden weiteren Adapter für denselben Track abfragen.

direction: down

input: "Quell-Track\n+ Quell-Adapter" {
  shape: rectangle
  style.fill: "#cce5ff"
}

active: "Aktive Adapter\n(eingeschaltet, mit Schlüssel)" {
  shape: step
}

input -> active

filter_self: "Quell-Adapter\nvon Zielen ausschließen" {
  shape: step
}

active -> filter_self

per_adapter: "Pro übrigen Adapter:\nparallel mit Zeitschranke" {
  shape: step
}

filter_self -> per_adapter

isrc_strategy: "Strategie 1: Suche per ISRC\n(falls Adapter unterstützt\nund Track ISRC hat)" {
  shape: rectangle
  style.fill: "#cce5ff"
}

search_strategy: "Strategie 2: Textsuche\nnach Titel und Interpret" {
  shape: rectangle
  style.fill: "#fff3cd"
}

per_adapter -> isrc_strategy: "erste Wahl"
isrc_strategy -> search_strategy: "kein ISRC-Match"

confidence_filter: "Treffer mit geringer Konfidenz filtern\n(außer synthetische Such-Notlösungen)" {
  shape: diamond
  style.fill: "#f5f5f5"
}

per_adapter -> confidence_filter: "alle abgeschlossen"

derive_yt_music: "YouTube-Music-Link ableiten\n(gleiche Kennung\nauf Schwester-Hostname)" {
  shape: step
}

confidence_filter -> derive_yt_music

yt_search_fallback: "Synthetische Such-Notlösung,\nwenn kein direktes Video-Match" {
  shape: step
  style.fill: "#fff3cd"
}

derive_yt_music -> yt_search_fallback

sort: "Nach Konfidenz sortieren" {
  shape: step
}

yt_search_fallback -> sort

result: "Dienstübergreifende Links" {
  shape: parallelogram
  style.fill: "#cce5ff"
}

sort -> result

# Varianten für Alben und Interpreten

album_variant: "Album-Variante" {
  shape: cloud
  style.fill: "#e2d4f0"
}

album_strategies: "Strategien in Reihenfolge:\nUPC-Suche,\nISRC-Ableitung (Tracks\nstichprobenartig prüfen,\nAlbum-Name abstimmen),\nTextsuche" {
  shape: rectangle
}

album_variant -> album_strategies

artist_variant: "Interpret-Variante" {
  shape: cloud
  style.fill: "#e2d4f0"
}

artist_scoring: "Konfidenzformel auf Namensähnlichkeit\nmit Bonus für exakte Treffer\nund präfix-bereinigte Gleichheit" {
  shape: rectangle
}

artist_variant -> artist_scoring

constants: "Konfidenz-Schwellwerte\nliegen zentral in einem\ngemeinsamen Konstantenmodul" {
  shape: rectangle
  style.fill: "#fff8e1"
}
