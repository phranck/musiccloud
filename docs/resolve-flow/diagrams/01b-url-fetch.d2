# URL-Pfad, Teil 2: Metadaten-Abruf, dienstübergreifende Suche, Abschluss.

direction: down

start: "Aus Cache-Suche und Quell-Bestimmung" {
  shape: parallelogram
  style.fill: "#d4edda"
}

extract: "Track-Kennung aus URL extrahieren" {
  shape: step
}

err_invalid: "Fehler: ungültige URL" {
  shape: rectangle
  style.fill: "#f8d7da"
}

start -> extract
extract -> err_invalid: "keine Kennung extrahierbar"

fetch: "Track-Metadaten\nbeim Quell-Dienst abrufen" {
  shape: step
  style.fill: "#cce5ff"
}

scrape: "Notlösung: Seite auslesen\n(Open-Graph-Metatags)" {
  shape: step
  style.fill: "#fff3cd"
}

extract -> fetch: "Kennung extrahiert"
fetch -> scrape: "Adapter mit Schlüssel\nfehlgeschlagen, Notlösung"

cache_isrc: "Cache-Suche per ISRC\n(nachträgliche Deduplikation für\ndieselbe Aufnahme über andere URL)" {
  shape: cylinder
  style.fill: "#fff8e1"
}

cross: "Dienstübergreifende Suche" {
  shape: cloud
  style.fill: "#cce5ff"
}

fetch -> cache_isrc
cache_isrc -> cross: "Miss"

enrich_artwork: "Cover-Notlösungskette\n(falls Quell-Dienst\nkein Cover liefert)" {
  shape: step
  style.fill: "#fff3cd"
}

prefer_stable: "Stabilste Vorschauquelle bevorzugen\n(dauerhafte CDN-URLs vor signierten)" {
  shape: step
  style.fill: "#fff3cd"
}

cross -> enrich_artwork
enrich_artwork -> prefer_stable

result: "Aufgelöster Track" {
  shape: parallelogram
  style.fill: "#cce5ff"
}

cache_isrc -> result: "Treffer"
prefer_stable -> result
scrape -> result: "Auslesung erfolgreich"
