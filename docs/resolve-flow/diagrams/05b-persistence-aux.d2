# Persistenz, Teil 2: externe Kennungen, Vorschauen, Alias, Vorschau-Erneuerung.

direction: down

input: "Aus kanonischem Schreibvorgang" {
  shape: parallelogram
  style.fill: "#d4edda"
}

ext_ids: "Externe Kennungen aggregieren\nüber alle kontaktierten Dienste\n(idempotenter Insert)" {
  shape: step
  style.fill: "#fff3cd"
}

input -> ext_ids

per_link_preview: "Vorschau-URLs per Upsert\npro dienstübergreifendem Link\nmit Ablaufzeit" {
  shape: step
  style.fill: "#fff3cd"
}

source_preview: "Vorschau-URL vom\nQuell-Dienst per Upsert" {
  shape: step
  style.fill: "#fff3cd"
}

ext_ids -> per_link_preview
per_link_preview -> source_preview

alias: "Kurzlink-Alias speichern\n(falls Eingabe Kurzlink war,\nder aufgelöst wurde)" {
  shape: step
  style.fill: "#fff3cd"
}

source_preview -> alias

deezer_check: "Vorschau-Erneuerung nötig?\n(fehlt oder abgelaufen,\nTrack hat ISRC)" {
  shape: diamond
  style.fill: "#f5f5f5"
}

alias -> deezer_check

deezer_refresh: "Vorschau aus stabilster Quelle\nneu holen" {
  shape: step
  style.fill: "#fff3cd"
}

deezer_check -> deezer_refresh: "ja"

result: "Persistenz-Ergebnis\n(kanonische Kennung, Share-Kurz-ID,\nerneuerte Vorschau-URL)" {
  shape: parallelogram
  style.fill: "#cce5ff"
}

deezer_check -> result: "nein"
deezer_refresh -> result

response_route: "Route-Layer:\nnutzersichtbare Antwort\nzusammenstellen" {
  shape: parallelogram
}

response_crawler: "Crawler-Layer:\nals ingestiert verbuchen" {
  shape: parallelogram
  style.fill: "#e2d4f0"
}

result -> response_route
result -> response_crawler
