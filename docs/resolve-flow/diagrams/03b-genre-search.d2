# Genre-Suche: strukturierte Anfrage gegen das Discovery-Backend.

direction: down

input: "Genre-Such-Anfrage" {
  shape: rectangle
  style.fill: "#d4edda"
}

parse: "Eingabe-Syntax parsen\n(Genre-Liste, Typ-Anzahlen,\nVibe-Auswahl)" {
  shape: step
}

err_parse: "Fehler: ungültige Syntax" {
  shape: rectangle
  style.fill: "#f8d7da"
}

err_no_key: "Fehler: Backend nicht konfiguriert" {
  shape: rectangle
  style.fill: "#f8d7da"
}

input -> parse
parse -> err_parse: "ungültige Syntax"
parse -> err_no_key: "Backend nicht verfügbar"

batch: "Pro Genre Batch-Abruf\nparallel" {
  shape: step
  style.fill: "#fff3cd"
}

parse -> batch: "gültig"

interleave: "Genres mischen\nund deduplizieren" {
  shape: step
}

sample: "Auswahlstrategie" {
  shape: diamond
  style.fill: "#f5f5f5"
}

batch -> interleave -> sample

hot: "Vibe: hot\n(Top-N oder gleichverteilt)" {
  shape: rectangle
}

mixed: "Vibe: mixed\n(geschichtet aus\nSpitze, Mitte, Schweif)" {
  shape: rectangle
}

sample -> hot: "Richtung Popularität"
sample -> mixed: "Richtung Entdeckung"

enrich: "Cover-Anreicherung\naus dauerhaftem Cache" {
  shape: step
}

hot -> enrich
mixed -> enrich

response: "Genre-Such-Antwort\n(Tracks, Alben, Interpreten\nplus Parser-Warnungen)" {
  shape: parallelogram
  style.fill: "#d4edda"
}

enrich -> response
