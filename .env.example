# Spotify (OAuth 2.0 Client Credentials)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Apple Music (JWT Developer Token)
APPLE_MUSIC_KEY_ID=
APPLE_MUSIC_TEAM_ID=
APPLE_MUSIC_PRIVATE_KEY=

# YouTube (API Key)
YOUTUBE_API_KEY=

# Odesli (optional, for higher rate limits)
ODESLI_API_KEY=

# Internal API key for Frontend → Backend communication (BFF)
# Must match INTERNAL_API_KEY in apps/frontend/.env.local
INTERNAL_API_KEY=

# JWT secret for public API (iOS/macOS apps)
JWT_SECRET=

# Database
# DATABASE_TYPE: "sqlite" (default), "postgres", or "mysql"
DATABASE_TYPE=sqlite

# SQLite (default)
DATABASE_PATH=data/music.db

# PostgreSQL (when DATABASE_TYPE=postgres)
# DATABASE_URL=postgresql://user:password@localhost:5432/music

# MySQL (when DATABASE_TYPE=mysql)
# DATABASE_HOST=localhost
# DATABASE_PORT=3306
# DATABASE_USER=root
# DATABASE_PASSWORD=
# DATABASE_NAME=music
