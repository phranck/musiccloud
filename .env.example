# Spotify (OAuth 2.0 Client Credentials)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Apple Music (JWT Developer Token)
APPLE_MUSIC_KEY_ID=
APPLE_MUSIC_TEAM_ID=
APPLE_MUSIC_PRIVATE_KEY=

# YouTube (API Key)
YOUTUBE_API_KEY=

# Internal API key for Frontend → Backend communication (BFF)
# Must match INTERNAL_API_KEY in apps/frontend/.env.local
INTERNAL_API_KEY=

# JWT secret for public API (iOS/macOS apps)
JWT_SECRET=

# Database (PostgreSQL)
DATABASE_URL=postgresql://musiccloud:password@localhost:5432/musiccloud
