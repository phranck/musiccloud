{
  "name": "musiccloud/sdk-candidate-harness",
  "description": "Native verification harness for the generated MusicCloud PHP SDK candidate.",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": ">=8.1 <8.6",
    "jane-php/open-api-runtime": "^7.12"
  },
  "require-dev": {
    "jane-php/open-api-3-1": "^7.12"
  },
  "autoload": {
    "psr-4": {
      "MusicCloud\\Generated\\": "generated/"
    }
  },
  "config": {
    "allow-plugins": {
      "php-http/discovery": true
    },
    "sort-packages": true
  }
}
