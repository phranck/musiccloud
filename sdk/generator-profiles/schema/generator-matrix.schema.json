{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://musiccloud.io/schemas/sdk-generator-matrix-v1.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "comparisonPolicy", "languages"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 1 },
    "comparisonPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["automaticFallback", "publishCandidates", "adapter"],
      "properties": {
        "automaticFallback": { "const": false },
        "publishCandidates": { "const": false },
        "adapter": { "$ref": "#/definitions/adapter" }
      }
    },
    "languages": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["language", "stability", "adapters"],
        "properties": {
          "language": { "enum": ["typescript", "python", "swift", "php", "go"] },
          "stability": { "enum": ["preview", "stable"] },
          "adapters": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "#/definitions/adapter" }
          }
        }
      }
    }
  },
  "definitions": {
    "adapter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "role",
        "name",
        "version",
        "license",
        "source",
        "artifact",
        "runtime",
        "dependencies",
        "limitations"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "role": { "enum": ["selected", "comparison"] },
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "license": { "enum": ["MIT", "Apache-2.0"] },
        "source": { "type": "string", "format": "uri" },
        "artifact": {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "locator", "digestAlgorithm", "digest"],
          "properties": {
            "type": { "enum": ["npm", "pypi-wheel", "git", "composer-dist", "go-module", "oci-index"] },
            "locator": { "type": "string", "minLength": 1 },
            "digestAlgorithm": { "enum": ["sha1", "sha256", "sha512", "git-commit", "go-sum"] },
            "digest": { "type": "string", "minLength": 7 }
          }
        },
        "runtime": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "constraint"],
          "properties": {
            "name": { "enum": ["node", "python", "swift", "php", "go", "docker"] },
            "constraint": { "type": "string", "minLength": 1 }
          }
        },
        "dependencies": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "limitations": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
