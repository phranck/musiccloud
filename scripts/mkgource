#!/usr/bin/env bash
# Renders Gource animation of the musiccloud.io WebApp repo and exports MP4 + HLS.
# If .gource/background.mp3 (or .m4a/.wav/.ogg) exists, it's mixed in as audio.
#
# Output: .gource/musiccloud-history.mp4
# HLS:    .gource/musiccloud-history-hls/index.m3u8
# Poster: .gource/musiccloud-history-hls/poster.jpg
#
# Usage: ./mkgource [options]

set -euo pipefail

VERSION="1.3.1"
SCRIPT_SOURCE="${BASH_SOURCE[0]}"
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_SOURCE")" && pwd -P)"
SCRIPT_PATH="$SCRIPT_DIR/$(basename "$SCRIPT_SOURCE")"

# Config, avatars and output live at the git repo root (one level above
# scripts/), not next to the script. Anchor the working dir there.
PROJECT_ROOT="$(git -C "$SCRIPT_DIR" rev-parse --show-toplevel 2>/dev/null || true)"
if [[ -z "$PROJECT_ROOT" ]]; then
  PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd -P)"
fi

cd "$PROJECT_ROOT"

CONFIG_FILE=".gource.conf"
AVATAR_DIR="$PROJECT_ROOT/.gource/avatars"
OUTPUT=".gource/musiccloud-history.mp4"
SILENT=".gource/musiccloud-history-silent.mp4"
HLS_DIR=".gource/musiccloud-history-hls"
HLS_SEGMENT_SECONDS=6
POSTER_TIME_SECONDS=3
AUDIO_VOLUME=0.75
GOURCE_VIEWPORT="2560x1440"
GOURCE_VIEWPORT_SET=0
# Timezone for the on-screen timestamps. Gource has no timezone flag; it formats
# commit times via libc localtime, so we steer it through the TZ env var. Empty
# uses the rendering machine's local zone (the default); set e.g. UTC to override.
RENDER_TZ=""
AUDIO_CROSSFADE_SECONDS=4
AUDIO_FADE_IN_SECONDS=3
AUDIO_FADE_OUT_SECONDS=3
GOURCE_BIN="${GOURCE_BIN:-}"
FFMPEG_BIN="${FFMPEG_BIN:-}"
FFPROBE_BIN="${FFPROBE_BIN:-}"
FFMPEG_CMD=""
FFPROBE_CMD=""
FFMPEG_QUIET_ARGS=(-hide_banner -loglevel error -nostats)
GENERATE_HLS=1
HLS_ONLY=0
USE_AUDIO=1
AUDIO=""
HLS_FROM=""
KEY_OVERRIDE=""
ANIMATION_FONT=""
ANIMATION_FONT_FILE=""
ANIMATION_FONT_COLOR=""
ANIMATION_FILENAME_COLOR=""
ANIMATION_DIR_COLOR=""
ANIMATION_HIGHLIGHT_COLOR=""
ANIMATION_SELECTION_COLOR=""
ANIMATION_FONT_SIZE=""
ANIMATION_DATE_FORMAT=""
ANIMATION_DATE_FORMAT_SET=0
ANIMATION_DATE_VISIBILITY=""
GOURCE_TITLE_OVERRIDE=""
GOURCE_TITLE_OVERRIDE_SET=0
RENDER_DURATION=""
OUTPUT_SET=0
TEMP_DIR=""

INTRO_ENABLED=1
INTRO_TITLE="musiccloud.io"
INTRO_SUBTITLE="a visualized development history"
INTRO_TITLE_FONT="Audiowide"
INTRO_SUBTITLE_FONT="Helvetica Neue"
INTRO_TITLE_FONT_SIZE=72
INTRO_SUBTITLE_FONT_SIZE=28
INTRO_TITLE_COLOR="FFFFFF"
INTRO_SUBTITLE_COLOR="CCCCCC"
INTRO_TITLE_FADE_IN=0.75
INTRO_SUBTITLE_DELAY=2.5
INTRO_SUBTITLE_FADE_IN=0.75
INTRO_HOLD=2
INTRO_TEXT_FADE_OUT=0
INTRO_CROSSFADE=1

OUTRO_ENABLED=0
OUTRO_TITLE=""
OUTRO_SUBTITLE=""
OUTRO_TITLE_FONT="Audiowide"
OUTRO_SUBTITLE_FONT="Helvetica Neue"
OUTRO_TITLE_FONT_SIZE=72
OUTRO_SUBTITLE_FONT_SIZE=28
OUTRO_TITLE_COLOR="FFFFFF"
OUTRO_SUBTITLE_COLOR="CCCCCC"
OUTRO_TITLE_FADE_IN=0.75
OUTRO_SUBTITLE_DELAY=2.5
OUTRO_SUBTITLE_FADE_IN=0.75
OUTRO_HOLD=2
OUTRO_TEXT_FADE_OUT=0
OUTRO_CROSSFADE=1

cleanup_temp_files() {
  if [[ -n "$TEMP_DIR" && -d "$TEMP_DIR" ]]; then
    rm -rf "$TEMP_DIR"
  fi
}

trap cleanup_temp_files EXIT

print_help_row() {
  local label="$1"
  local description="$2"

  printf '  %-31s %s\n' "$label" "$description"
}

