  cat <<'EOF'
Usage:
  ./mkgource [options]
  ./mkgource render [options]
  ./mkgource hls [options]
  ./mkgource help
  ./mkgource version

Commands:
EOF
  print_help_row "render" "Render MP4 and package HLS output. Default command."
  print_help_row "hls" "Render HLS only, or package --from MP4 as HLS."
  print_help_row "help" "Show this help text and exit."
  print_help_row "version" "Show wrapper version and exit."

  printf '\nOptions:\n'
  print_help_row "-h, --help" "Show this help text and exit."
  print_help_row "-V, --version" "Show wrapper version and exit."
