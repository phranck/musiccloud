        shift 2
        ;;
      --)
        shift
        break
        ;;
      -*)
        die "Unknown option: $1"
        ;;
      *)
        die "Unknown command or argument: $1"
        ;;
    esac
  done
}

title_card_has_content() {
  [[ -n "$1" || -n "$2" ]]
}

title_cards_require_drawtext() {
  if [[ "$INTRO_ENABLED" -eq 1 ]] && title_card_has_content "$INTRO_TITLE" "$INTRO_SUBTITLE"; then
    return 0
  fi

  if [[ "$OUTRO_ENABLED" -eq 1 ]] && title_card_has_content "$OUTRO_TITLE" "$OUTRO_SUBTITLE"; then
    return 0
  fi

  return 1
}

validate_timing_options() {
  local pairs=(
    "duration:$RENDER_DURATION"
    "audio crossfade:$AUDIO_CROSSFADE_SECONDS"
    "audio fade-in:$AUDIO_FADE_IN_SECONDS"
    "audio fade-out:$AUDIO_FADE_OUT_SECONDS"
    "audio volume:$AUDIO_VOLUME"
    "animation font size:$ANIMATION_FONT_SIZE"
    "intro title font size:$INTRO_TITLE_FONT_SIZE"
    "intro subtitle font size:$INTRO_SUBTITLE_FONT_SIZE"
    "intro title fade-in:$INTRO_TITLE_FADE_IN"
    "intro subtitle delay:$INTRO_SUBTITLE_DELAY"
    "intro subtitle fade-in:$INTRO_SUBTITLE_FADE_IN"
    "intro hold:$INTRO_HOLD"
    "intro fade-out:$INTRO_TEXT_FADE_OUT"
    "intro crossfade:$INTRO_CROSSFADE"
    "outro title font size:$OUTRO_TITLE_FONT_SIZE"
    "outro subtitle font size:$OUTRO_SUBTITLE_FONT_SIZE"
    "outro title fade-in:$OUTRO_TITLE_FADE_IN"
    "outro subtitle delay:$OUTRO_SUBTITLE_DELAY"
    "outro subtitle fade-in:$OUTRO_SUBTITLE_FADE_IN"
    "outro hold:$OUTRO_HOLD"
    "outro fade-out:$OUTRO_TEXT_FADE_OUT"
    "outro crossfade:$OUTRO_CROSSFADE"
  )
  local pair=""
  local name=""
  local value=""

  for pair in "${pairs[@]}"; do
    name="${pair%%:*}"
    value="${pair#*:}"
    [[ -z "$value" ]] && continue
    validate_number "$name" "$value"
  done
}

prepare_text_options() {
  if [[ "$OUTRO_ENABLED" -eq 1 && -z "$OUTRO_TITLE" && -z "$OUTRO_SUBTITLE" ]]; then
    OUTRO_TITLE="$INTRO_TITLE"
    OUTRO_SUBTITLE="$INTRO_SUBTITLE"
  fi

  INTRO_TITLE_COLOR="$(normalize_hex_color "intro title colour" "$INTRO_TITLE_COLOR" 1)"
  INTRO_SUBTITLE_COLOR="$(normalize_hex_color "intro subtitle colour" "$INTRO_SUBTITLE_COLOR" 1)"
  OUTRO_TITLE_COLOR="$(normalize_hex_color "outro title colour" "$OUTRO_TITLE_COLOR" 1)"
  OUTRO_SUBTITLE_COLOR="$(normalize_hex_color "outro subtitle colour" "$OUTRO_SUBTITLE_COLOR" 1)"
  ANIMATION_FONT_COLOR="$(normalize_optional_hex_color "animation font colour" "$ANIMATION_FONT_COLOR")"
  ANIMATION_FILENAME_COLOR="$(normalize_optional_hex_color "animation filename colour" "$ANIMATION_FILENAME_COLOR")"
  ANIMATION_DIR_COLOR="$(normalize_optional_hex_color "animation directory colour" "$ANIMATION_DIR_COLOR")"
  ANIMATION_HIGHLIGHT_COLOR="$(normalize_optional_hex_color "animation highlight colour" "$ANIMATION_HIGHLIGHT_COLOR")"
  ANIMATION_SELECTION_COLOR="$(normalize_optional_hex_color "animation selection colour" "$ANIMATION_SELECTION_COLOR")"

  if [[ -n "$ANIMATION_FONT" ]]; then
    ANIMATION_FONT_FILE="$(resolve_font_file "$ANIMATION_FONT")"
  fi
}

resolve_media_tools() {
  local drawtext_required=0

  if title_cards_require_drawtext; then
    drawtext_required=1
  fi

  FFMPEG_CMD="$(find_ffmpeg_binary "$drawtext_required")"
  FFPROBE_CMD="$(find_ffprobe_binary "$FFMPEG_CMD")"
}

detect_background_audio() {
  local ext=""

  if [[ "$USE_AUDIO" -eq 0 ]]; then
    return
  fi

  if [[ -n "$AUDIO" ]]; then
    [[ -f "$AUDIO" ]] || die "Audio file not found: $AUDIO"
    return
  fi

  for ext in mp3 m4a wav ogg; do
    if [[ -f ".gource/background.$ext" ]]; then
      AUDIO=".gource/background.$ext"
      return
    fi
  done
}

get_media_duration() {
  "$FFPROBE_CMD" -v error -show_entries format=duration -of csv=p=0 "$1"
}

clamp_fade_duration() {
  local media_duration="$1"
  local requested_duration="$2"

  awk -v media="$media_duration" -v requested="$requested_duration" 'BEGIN {
    fade = requested;
    max = media / 2;
    if (fade > max) fade = max;
    if (fade < 0) fade = 0;
    printf "%.3f", fade;
  }'
}

clamp_duration_to_media() {
  local media_duration="$1"
  local requested_duration="$2"

  awk -v media="$media_duration" -v requested="$requested_duration" 'BEGIN {
    duration = requested;
    if (duration > media) duration = media;
    if (duration < 0) duration = 0;
    printf "%.3f", duration;
  }'
}

calculate_audio_repeats() {
  local video_duration="$1"
  local audio_duration="$2"
  local crossfade_duration="$3"

  awk -v video="$video_duration" -v audio="$audio_duration" -v fade="$crossfade_duration" 'BEGIN {
    if (video <= audio) {
      print 1;
      exit;
    }

    step = audio - fade;
    if (step <= 0) step = audio;

    repeats = 1;
    duration = audio;
    while (duration < video) {
      repeats += 1;
      duration += step;
    }

    print repeats;
  }'
}

build_audio_filter() {
  local video_duration="$1"
  local repeat_count="$2"
  local crossfade_duration="$3"
  local fade_in_duration="$4"
  local fade_out_duration="$5"
  local fade_out_start="$6"

  local filter=""
  local previous_label=""
  local next_label=""
  local i=0

  for ((i = 0; i < repeat_count; i++)); do
    filter+="[$((i + 1)):a]aformat=sample_fmts=fltp:sample_rates=48000:channel_layouts=stereo,volume=${AUDIO_VOLUME}[a${i}];"
  done

  previous_label="a0"
  for ((i = 1; i < repeat_count; i++)); do
    next_label="xf${i}"
    filter+="[${previous_label}][a${i}]acrossfade=d=${crossfade_duration}:c1=tri:c2=tri[${next_label}];"
    previous_label="$next_label"
  done

  filter+="[${previous_label}]atrim=0:${video_duration},asetpts=N/SR/TB"
  if awk -v fade="$fade_in_duration" 'BEGIN { exit !(fade > 0) }'; then
    filter+=",afade=t=in:d=${fade_in_duration}"
  fi
  if awk -v fade="$fade_out_duration" 'BEGIN { exit !(fade > 0) }'; then
    filter+=",afade=t=out:st=${fade_out_start}:d=${fade_out_duration}"
  fi
  filter+="[audio]"

  printf "%s" "$filter"
}

text_ready_time() {
  local title="$1"
  local subtitle="$2"
  local title_fade_in="$3"
  local subtitle_delay="$4"
  local subtitle_fade_in="$5"
  local title_ready=0
  local subtitle_ready=0

  if [[ -n "$title" ]]; then
    title_ready="$title_fade_in"
  fi

  if [[ -n "$subtitle" ]]; then
    subtitle_ready="$(number_add "$subtitle_delay" "$subtitle_fade_in")"
  fi

  number_max "$title_ready" "$subtitle_ready"
}

title_card_visible_duration() {
  local title="$1"
  local subtitle="$2"
  local title_fade_in="$3"
  local subtitle_delay="$4"
  local subtitle_fade_in="$5"
  local hold_duration="$6"
  local fade_out_duration="$7"
  local ready=""
  local with_hold=""

  ready="$(text_ready_time "$title" "$subtitle" "$title_fade_in" "$subtitle_delay" "$subtitle_fade_in")"
  with_hold="$(number_add "$ready" "$hold_duration")"
  number_add "$with_hold" "$fade_out_duration"
}

build_text_alpha_expression() {
  local delay="$1"
  local fade_in="$2"
  local fade_out="$3"
  local duration="$4"
  local full_at=""
  local fade_out_start=""
  local base=""

  full_at="$(number_add "$delay" "$fade_in")"

  if number_gt "$fade_in" 0; then
    if number_gt "$delay" 0; then
      base="if(lt(t\\,$delay)\\,0\\,if(lt(t\\,$full_at)\\,(t-$delay)/$fade_in\\,1))"
    else
      base="if(lt(t\\,$fade_in)\\,t/$fade_in\\,1)"
    fi
  elif number_gt "$delay" 0; then
    base="if(lt(t\\,$delay)\\,0\\,1)"
  else
    base="1"
  fi

  if number_gt "$fade_out" 0; then
    fade_out_start="$(number_subtract "$duration" "$fade_out")"
    printf "if(lt(t\\,%s)\\,%s\\,min(%s\\,(%s-t)/%s))" \
      "$fade_out_start" "$base" "$base" "$duration" "$fade_out"
  else
    printf "%s" "$base"
  fi
}

generate_title_card() {
  local output="$1"
  local title="$2"
  local subtitle="$3"
  local title_font="$4"
  local subtitle_font="$5"
  local title_font_size="$6"
  local subtitle_font_size="$7"
  local title_color="$8"
  local subtitle_color="$9"
  local title_fade_in="${10}"
  local subtitle_delay="${11}"
  local subtitle_fade_in="${12}"
  local hold_duration="${13}"
  local text_fade_out="${14}"
  local card_duration="${15}"
  local title_file=""
  local subtitle_file=""
  local title_alpha=""
  local title_drawtext_color=""
  local subtitle_alpha=""
  local subtitle_drawtext_color=""
  local filters=()
  local filter=""

  title_file="$TEMP_DIR/title-$(basename "$output").txt"
  subtitle_file="$TEMP_DIR/subtitle-$(basename "$output").txt"

  if [[ -n "$title" ]]; then
    printf "%s" "$title" > "$title_file"
    title_alpha="$(build_text_alpha_expression 0 "$title_fade_in" "$text_fade_out" "$card_duration")"
    title_drawtext_color="$(drawtext_color "$title_color")"
    filters+=("drawtext=font='$title_font':textfile='$title_file':fontcolor=$title_drawtext_color:fontsize=$title_font_size:x=(w-text_w)/2:y=(h-text_h)/2-26:alpha='$title_alpha'")
  fi

  if [[ -n "$subtitle" ]]; then
    printf "%s" "$subtitle" > "$subtitle_file"
    subtitle_alpha="$(build_text_alpha_expression "$subtitle_delay" "$subtitle_fade_in" "$text_fade_out" "$card_duration")"
    subtitle_drawtext_color="$(drawtext_color "$subtitle_color")"
    filters+=("drawtext=font='$subtitle_font':textfile='$subtitle_file':fontcolor=$subtitle_drawtext_color:fontsize=$subtitle_font_size:x=(w-text_w)/2:y=(h-text_h)/2+44:alpha='$subtitle_alpha'")
  fi

  if ((${#filters[@]})); then
    IFS=,
    filter="${filters[*]}"
    unset IFS
  else
    filter="null"
  fi

  run_ffmpeg "title card" -y \
    -f lavfi \
    -i "color=c=black:s=${GOURCE_VIEWPORT}:r=60:d=${card_duration}" \
    -vf "$filter" \
    -an \
    -c:v libx264 -preset medium -pix_fmt yuv420p -crf 18 \
    -g 120 -keyint_min 120 -sc_threshold 0 \
    "$output"
}

limit_video_duration() {
  local input="$1"
  local output="$2"

  if [[ -z "$RENDER_DURATION" ]]; then
    if [[ "$input" != "$output" ]]; then
      mv "$input" "$output"
    fi
    return
  fi

  run_ffmpeg "duration limit" -y -i "$input" \
    -vf "tpad=stop_mode=clone:stop_duration=2,trim=duration=${RENDER_DURATION},setpts=PTS-STARTPTS" \
    -an \
    -c:v libx264 -preset medium -pix_fmt yuv420p -crf 18 \
    -g 120 -keyint_min 120 -sc_threshold 0 \
    "$output"
}

compose_video_with_title_cards() {
  local raw_video="$1"
  local output="$2"
  local current_video="$raw_video"
  local intro_video=""
  local outro_video=""
  local intro_offset=""
  local intro_duration=""
  local outro_duration=""
  local current_duration=""
  local outro_offset=""

  if [[ "$INTRO_ENABLED" -eq 1 ]] && title_card_has_content "$INTRO_TITLE" "$INTRO_SUBTITLE"; then
    log_step "Compositing intro title screen..."
    intro_offset="$(title_card_visible_duration "$INTRO_TITLE" "$INTRO_SUBTITLE" "$INTRO_TITLE_FADE_IN" "$INTRO_SUBTITLE_DELAY" "$INTRO_SUBTITLE_FADE_IN" "$INTRO_HOLD" "$INTRO_TEXT_FADE_OUT")"
    intro_duration="$(number_add "$intro_offset" "$INTRO_CROSSFADE")"
    generate_title_card "$TEMP_DIR/intro.mp4" "$INTRO_TITLE" "$INTRO_SUBTITLE" "$INTRO_TITLE_FONT" "$INTRO_SUBTITLE_FONT" "$INTRO_TITLE_FONT_SIZE" "$INTRO_SUBTITLE_FONT_SIZE" "$INTRO_TITLE_COLOR" "$INTRO_SUBTITLE_COLOR" "$INTRO_TITLE_FADE_IN" "$INTRO_SUBTITLE_DELAY" "$INTRO_SUBTITLE_FADE_IN" "$INTRO_HOLD" "$INTRO_TEXT_FADE_OUT" "$intro_duration"
    intro_video="$TEMP_DIR/with-intro.mp4"
    run_ffmpeg "intro crossfade" -y \
      -i "$TEMP_DIR/intro.mp4" \
      -i "$current_video" \
      -filter_complex "[0:v][1:v]xfade=transition=fade:duration=${INTRO_CROSSFADE}:offset=${intro_offset},format=yuv420p[v]" \
      -map "[v]" \
      -an \
      -c:v libx264 -preset medium -pix_fmt yuv420p -crf 18 \
      -g 120 -keyint_min 120 -sc_threshold 0 \
      "$intro_video"
    current_video="$intro_video"
  fi

  if [[ "$OUTRO_ENABLED" -eq 1 ]] && title_card_has_content "$OUTRO_TITLE" "$OUTRO_SUBTITLE"; then
    log_step "Compositing outro title screen..."
    outro_duration="$(title_card_visible_duration "$OUTRO_TITLE" "$OUTRO_SUBTITLE" "$OUTRO_TITLE_FADE_IN" "$OUTRO_SUBTITLE_DELAY" "$OUTRO_SUBTITLE_FADE_IN" "$OUTRO_HOLD" "$OUTRO_TEXT_FADE_OUT")"
    current_duration="$(get_media_duration "$current_video")"
    outro_offset="$(number_subtract "$current_duration" "$OUTRO_CROSSFADE")"
    if ! number_gt "$outro_offset" 0; then
      die "Outro crossfade (${OUTRO_CROSSFADE}s) is longer than the rendered video (${current_duration}s)"
    fi
    generate_title_card "$TEMP_DIR/outro.mp4" "$OUTRO_TITLE" "$OUTRO_SUBTITLE" "$OUTRO_TITLE_FONT" "$OUTRO_SUBTITLE_FONT" "$OUTRO_TITLE_FONT_SIZE" "$OUTRO_SUBTITLE_FONT_SIZE" "$OUTRO_TITLE_COLOR" "$OUTRO_SUBTITLE_COLOR" "$OUTRO_TITLE_FADE_IN" "$OUTRO_SUBTITLE_DELAY" "$OUTRO_SUBTITLE_FADE_IN" "$OUTRO_HOLD" "$OUTRO_TEXT_FADE_OUT" "$outro_duration"
    outro_video="$TEMP_DIR/with-outro.mp4"
    run_ffmpeg "outro crossfade" -y \
      -i "$current_video" \
      -i "$TEMP_DIR/outro.mp4" \
      -filter_complex "[0:v][1:v]xfade=transition=fade:duration=${OUTRO_CROSSFADE}:offset=${outro_offset},format=yuv420p[v]" \
      -map "[v]" \
      -an \
      -c:v libx264 -preset medium -pix_fmt yuv420p -crf 18 \
      -g 120 -keyint_min 120 -sc_threshold 0 \
      "$outro_video"
    current_video="$outro_video"
  fi

  limit_video_duration "$current_video" "$output"
}

calculate_intro_duration_for_limit() {
  local intro_offset=0

  if [[ "$INTRO_ENABLED" -eq 1 ]] && title_card_has_content "$INTRO_TITLE" "$INTRO_SUBTITLE"; then
    intro_offset="$(title_card_visible_duration "$INTRO_TITLE" "$INTRO_SUBTITLE" "$INTRO_TITLE_FADE_IN" "$INTRO_SUBTITLE_DELAY" "$INTRO_SUBTITLE_FADE_IN" "$INTRO_HOLD" "$INTRO_TEXT_FADE_OUT")"
  fi

  printf "%s" "$intro_offset"
}

calculate_outro_extension_for_limit() {
  local outro_duration=0

  if [[ "$OUTRO_ENABLED" -eq 1 ]] && title_card_has_content "$OUTRO_TITLE" "$OUTRO_SUBTITLE"; then
    outro_duration="$(title_card_visible_duration "$OUTRO_TITLE" "$OUTRO_SUBTITLE" "$OUTRO_TITLE_FADE_IN" "$OUTRO_SUBTITLE_DELAY" "$OUTRO_SUBTITLE_FADE_IN" "$OUTRO_HOLD" "$OUTRO_TEXT_FADE_OUT")"
    number_subtract "$outro_duration" "$OUTRO_CROSSFADE"
    return
  fi

  printf "%s" "$outro_duration"
}

calculate_gource_stop_time() {
  local intro_duration=""
  local outro_extension=""
  local remaining=""

  [[ -n "$RENDER_DURATION" ]] || return

  intro_duration="$(calculate_intro_duration_for_limit)"
  outro_extension="$(calculate_outro_extension_for_limit)"
  remaining="$(awk -v total="$RENDER_DURATION" -v intro="$intro_duration" -v outro="$outro_extension" 'BEGIN {
    value = total - intro - outro;
    printf "%.3f", value;
  }')"

  if ! number_gt "$remaining" 0; then
    die "Duration ${RENDER_DURATION}s is too short for the configured intro/outro timing"
  fi

  printf "%s" "$remaining"
}

generate_hls_output() {
  local input="$1"
  local playlist="$HLS_DIR/index.m3u8"
  local poster="$HLS_DIR/poster.jpg"

  rm -rf "$HLS_DIR"
  mkdir -p "$HLS_DIR"

  log_step "Packaging HLS segments..."
  run_ffmpeg "HLS packaging" -y -i "$input" \
    -map 0:v:0 -map "0:a?" \
    -c:v copy -c:a copy \
    -hls_time "$HLS_SEGMENT_SECONDS" \
    -hls_playlist_type vod \
    -hls_flags independent_segments \
    -hls_segment_filename "$HLS_DIR/segment_%03d.ts" \
    "$playlist"

  log_step "Generating HLS poster..."
  if ! try_ffmpeg "HLS poster seek" -y -ss "$POSTER_TIME_SECONDS" -i "$input" -frames:v 1 -q:v 2 "$poster" ||
    [[ ! -s "$poster" ]]; then
    rm -f "$poster"
    run_ffmpeg "HLS poster fallback" -y -i "$input" -frames:v 1 -q:v 2 "$poster"
  fi

  [[ -s "$poster" ]] || die "Failed to generate HLS poster: $poster"
}

render_video() {
  local gource_binary="$1"
  local effective_config=""
  local raw_video=""
  local gource_stop_time=""
  local gource_args=()
  local ffmpeg_duration_args=()
  local pipeline_status=0
  local video_duration=""
  local audio_duration=""
  local crossfade_duration=""
  local fade_in_duration=""
  local fade_out_duration=""
  local fade_out_start=""
  local audio_repeats=""
  local audio_filter=""
  local audio_inputs=()
  local i=0

  [[ -f "$CONFIG_FILE" ]] || die "Gource config not found: $CONFIG_FILE"
  [[ -d "$AVATAR_DIR" ]] || die "Avatar directory not found: $AVATAR_DIR"
  ensure_temp_dir
  effective_config="$(build_effective_gource_config)"
  raw_video="$TEMP_DIR/gource-raw.mp4"

  gource_args=(
    --load-config "$effective_config"
    "-$GOURCE_VIEWPORT"
    --user-image-dir "$AVATAR_DIR"
    --disable-input
  )

  if [[ -n "$RENDER_DURATION" ]]; then
    gource_stop_time="$(calculate_gource_stop_time)"
    gource_args+=(--stop-at-time "$gource_stop_time")
    log_step "Rendering ${RENDER_DURATION}s video at $GOURCE_VIEWPORT..."
  else
    gource_args+=(--stop-at-end)
    log_step "Rendering repo history at $GOURCE_VIEWPORT..."
  fi

  if [[ -n "$gource_stop_time" ]]; then
    ffmpeg_duration_args=(-t "$gource_stop_time")
    set +o pipefail
  fi

  local gource_env=()
  if [[ -n "$RENDER_TZ" ]]; then
    gource_env=(env "TZ=$RENDER_TZ")
  fi

  set +e
  "${gource_env[@]}" "$gource_binary" "${gource_args[@]}" -o - \
  | run_ffmpeg "Gource video stream" -y -r 60 -f image2pipe -vcodec ppm -i - \
      "${ffmpeg_duration_args[@]}" \
      -vcodec libx264 -preset medium -pix_fmt yuv420p -crf 18 \
      -g 120 -keyint_min 120 -sc_threshold 0 \
      "$raw_video"
  pipeline_status=$?
  set -e

  if [[ -n "$gource_stop_time" ]]; then
    set -o pipefail
  fi

  [[ "$pipeline_status" -eq 0 ]] || die "Failed to render Gource video stream"
  [[ -s "$raw_video" ]] || die "Gource raw video was not created: $raw_video"

  compose_video_with_title_cards "$raw_video" "$SILENT"

  if [[ -n "$AUDIO" ]]; then
    log_step "Mixing audio..."
    video_duration="$(get_media_duration "$SILENT")"
    audio_duration="$(get_media_duration "$AUDIO")"
    crossfade_duration="$(clamp_fade_duration "$audio_duration" "$AUDIO_CROSSFADE_SECONDS")"
    fade_in_duration="$(clamp_duration_to_media "$video_duration" "$AUDIO_FADE_IN_SECONDS")"
    fade_out_duration="$(clamp_duration_to_media "$video_duration" "$AUDIO_FADE_OUT_SECONDS")"
    fade_out_start="$(awk -v video="$video_duration" -v fade="$fade_out_duration" 'BEGIN {
      start = video - fade;
      if (start < 0) start = 0;
      printf "%.3f", start;
    }')"
    audio_repeats="$(calculate_audio_repeats "$video_duration" "$audio_duration" "$crossfade_duration")"
    audio_filter="$(build_audio_filter "$video_duration" "$audio_repeats" "$crossfade_duration" "$fade_in_duration" "$fade_out_duration" "$fade_out_start")"

    for ((i = 0; i < audio_repeats; i++)); do
      audio_inputs+=(-i "$AUDIO")
    done

    run_ffmpeg "audio mix" -y -i "$SILENT" "${audio_inputs[@]}" \
      -filter_complex "$audio_filter" \
      -map 0:v:0 -map "[audio]" \
      -c:v copy -c:a aac -b:a 192k \
      -shortest -movflags +faststart \
      "$OUTPUT"
  else
    log_step "Writing final MP4..."
    run_ffmpeg "final MP4 write" -y -i "$SILENT" -c copy -movflags +faststart "$OUTPUT"
  fi

  rm "$SILENT"
}

main() {
  local gource_binary=""
  local hls_playlist=""
  local hls_poster=""
  local hls_input=""
  local final_mp4_output=""

  parse_args "$@"
  validate_timing_options
  prepare_text_options
  resolve_media_tools
  final_mp4_output="$OUTPUT"

  if [[ "$HLS_ONLY" -eq 1 && "$GENERATE_HLS" -eq 0 ]]; then
    die "hls/--hls-only cannot be combined with --no-hls"
  fi

  if [[ "$HLS_ONLY" -eq 1 && "$OUTPUT_SET" -eq 1 ]]; then
    die "--output writes a final MP4. Use --from FILE for an existing HLS source, or omit --output for HLS-only rendering."
  fi

  if [[ -n "$HLS_FROM" ]]; then
    [[ -f "$HLS_FROM" ]] || die "HLS source MP4 not found: $HLS_FROM"
    hls_input="$HLS_FROM"
  elif [[ "$HLS_ONLY" -eq 1 ]]; then
    detect_background_audio
    gource_binary="$(find_gource_binary)"
    TEMP_DIR="$(mktemp -d "${TMPDIR:-/tmp}/musiccloud-gource-hls.XXXXXX")"
    OUTPUT="$TEMP_DIR/render.mp4"
    render_video "$gource_binary"
    hls_input="$OUTPUT"
  else
    detect_background_audio
    gource_binary="$(find_gource_binary)"
    render_video "$gource_binary"
    hls_input="$OUTPUT"
  fi

  if [[ "$GENERATE_HLS" -eq 1 ]]; then
    log_step "Generating HLS output..."
    generate_hls_output "$hls_input"
    hls_playlist="$HLS_DIR/index.m3u8"
    hls_poster="$HLS_DIR/poster.jpg"
  fi

  if [[ "$HLS_ONLY" -eq 0 ]]; then
    echo "MP4  -> $final_mp4_output"
  elif [[ -n "$HLS_FROM" ]]; then
    echo "MP4 source -> $HLS_FROM"
  else
    echo "MP4  -> not kept (--hls-only)"
  fi

  if [[ "$GENERATE_HLS" -eq 1 ]]; then
    echo "HLS  -> $hls_playlist"
    echo "Poster -> $hls_poster"
  fi
}

main "$@"
