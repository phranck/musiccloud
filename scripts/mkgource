}

print_version() {
  printf "musiccloud gource renderer %s\n" "$VERSION"
}

log_step() {
  printf "%s\n" "$*"
}

run_ffmpeg_capture() {
  local emit_errors="$1"
  local label="$2"
  local log_file=""
  local status=0

  shift 2
  ensure_temp_dir
  log_file="$(mktemp "$TEMP_DIR/ffmpeg.XXXXXX.log")"

  if "$FFMPEG_CMD" "${FFMPEG_QUIET_ARGS[@]}" "$@" 2>"$log_file"; then
    rm -f "$log_file"
    return 0
  fi

  status=$?
  if [[ "$emit_errors" -eq 1 && -s "$log_file" ]]; then
    printf "ffmpeg failed during %s:\n" "$label" >&2
    cat "$log_file" >&2
  fi

  return "$status"
}

run_ffmpeg() {
  run_ffmpeg_capture 1 "$@"
}

try_ffmpeg() {
  run_ffmpeg_capture 0 "$@"
}

die() {
  printf "Error: %s\n" "$*" >&2
  printf "Run './mkgource --help' for usage.\n" >&2
  exit 1
}

require_value() {
  local flag="$1"
  local value="${2-}"

  if [[ -z "$value" || "$value" == -* ]]; then
    die "$flag requires a value"
  fi
}

resolve_path() {
  local path="$1"
  local dir=""
  local base=""

  if [[ "$path" != */* ]]; then
    path="$(command -v "$path" 2>/dev/null || printf "%s" "$path")"
  fi

  dir="$(cd "$(dirname "$path")" 2>/dev/null && pwd -P)" || return 1
  base="$(basename "$path")"
  printf "%s/%s\n" "$dir" "$base"
}

find_gource_binary() {
  local candidate=""
  local resolved_candidate=""

  if [[ -n "$GOURCE_BIN" ]]; then
    [[ -x "$GOURCE_BIN" ]] || die "Gource binary is not executable: $GOURCE_BIN"
    printf "%s\n" "$GOURCE_BIN"
    return
  fi

  while IFS= read -r candidate; do
    [[ -z "$candidate" ]] && continue
    resolved_candidate="$(resolve_path "$candidate" || true)"
    [[ -z "$resolved_candidate" ]] && continue

    if [[ "$resolved_candidate" != "$SCRIPT_PATH" ]]; then
      printf "%s\n" "$candidate"
      return
    fi
  done < <(type -P -a gource 2>/dev/null || true)

  die "Could not find the real Gource binary. Install gource or pass --gource-bin FILE."
}

require_command() {
  command -v "$1" >/dev/null 2>&1 || die "Required command not found: $1"
}

ffmpeg_supports_drawtext() {
  "$1" -hide_banner -filters 2>/dev/null | awk '/ drawtext / { found = 1 } END { exit !found }'
}

find_ffmpeg_binary() {
  local drawtext_required="$1"
  local candidate=""
  local candidates=()

  if [[ -n "$FFMPEG_BIN" ]]; then
    [[ -x "$FFMPEG_BIN" ]] || die "ffmpeg binary is not executable: $FFMPEG_BIN"
    if [[ "$drawtext_required" -eq 1 ]] && ! ffmpeg_supports_drawtext "$FFMPEG_BIN"; then
      die "ffmpeg binary does not support drawtext: $FFMPEG_BIN"
    fi
    printf "%s\n" "$FFMPEG_BIN"
    return
  fi

  if command -v ffmpeg >/dev/null 2>&1; then
    candidates+=("$(command -v ffmpeg)")
  fi
  candidates+=("/opt/homebrew/opt/ffmpeg-full/bin/ffmpeg")

  for candidate in "${candidates[@]}"; do
    [[ -x "$candidate" ]] || continue
    if [[ "$drawtext_required" -eq 0 ]] || ffmpeg_supports_drawtext "$candidate"; then
      printf "%s\n" "$candidate"
      return
    fi
  done

  if [[ "$drawtext_required" -eq 1 ]]; then
    die "Could not find an ffmpeg binary with drawtext support. Install ffmpeg-full or pass --ffmpeg-bin FILE."
  fi

  die "Required command not found: ffmpeg"
}

find_ffprobe_binary() {
  local ffmpeg_binary="$1"
  local sibling=""

  if [[ -n "$FFPROBE_BIN" ]]; then
    [[ -x "$FFPROBE_BIN" ]] || die "ffprobe binary is not executable: $FFPROBE_BIN"
    printf "%s\n" "$FFPROBE_BIN"
    return
  fi

  sibling="$(dirname "$ffmpeg_binary")/ffprobe"
  if [[ -x "$sibling" ]]; then
    printf "%s\n" "$sibling"
    return
  fi

  command -v ffprobe 2>/dev/null || die "Required command not found: ffprobe"
}

number_gt() {
  awk -v value="$1" -v limit="$2" 'BEGIN { exit !(value > limit) }'
}

number_add() {
  awk -v left="$1" -v right="$2" 'BEGIN { printf "%.3f", left + right }'
}

number_subtract() {
  awk -v left="$1" -v right="$2" 'BEGIN { printf "%.3f", left - right }'
}

number_max() {
  awk -v left="$1" -v right="$2" 'BEGIN {
    max = left;
    if (right > max) max = right;
    printf "%.3f", max;
  }'
}

validate_number() {
  local name="$1"
  local value="$2"

  awk -v value="$value" 'BEGIN { exit !(value ~ /^[0-9]+([.][0-9]+)?$/) }' ||
    die "$name must be a non-negative number: $value"
}

normalize_hex_color() {
  local name="$1"
  local value="$2"
  local allow_alpha="$3"
  local color="$value"
  local alpha=""
  local normalized=""

  [[ -n "$color" ]] || return 0

  if [[ "$color" == *"@"* ]]; then
    alpha="${color#*@}"
    color="${color%@*}"
    [[ "$allow_alpha" -eq 1 ]] || die "$name does not support alpha: $value"
    awk -v value="$alpha" 'BEGIN { exit !(value ~ /^([0-9]+([.][0-9]+)?|[.][0-9]+)$/ && value >= 0 && value <= 1) }' ||
      die "$name alpha must be between 0 and 1: $value"
  fi

  color="${color#0x}"
  color="${color#0X}"
  normalized="$(printf "%s" "$color" | tr '[:lower:]' '[:upper:]')"
  awk -v value="$normalized" 'BEGIN { exit !(value ~ /^[0-9A-F]{6}$/) }' ||
    die "$name must be a 6-digit hex colour without 0x: $value"

  if [[ -n "$alpha" ]]; then
    printf "%s@%s\n" "$normalized" "$alpha"
  else
    printf "%s\n" "$normalized"
  fi
}

normalize_optional_hex_color() {
  local name="$1"
  local value="$2"

  [[ -n "$value" ]] || return 0
  normalize_hex_color "$name" "$value" 0
}

normalize_viewport() {
  local value="$1"
  local normalized=""

  normalized="$(printf "%s" "$value" | tr '[:upper:]' '[:lower:]')"

  case "$normalized" in
    720p | hd)
      printf "1280x720\n"
      ;;
    1080p | fhd)
      printf "1920x1080\n"
      ;;
    1440p | qhd | wqhd | 2k)
      printf "2560x1440\n"
      ;;
    2160p | uhd | 4k)
      printf "3840x2160\n"
      ;;
    5k)
      printf "5120x2880\n"
      ;;
    *)
      awk -v value="$normalized" 'BEGIN { exit !(value ~ /^[1-9][0-9]*x[1-9][0-9]*$/) }' ||
        die "viewport must be one of 720p, 1080p, 1440p, 4k, 5k, or WIDTHxHEIGHT: $value"
      printf "%s\n" "$normalized"
      ;;
  esac
}

drawtext_color() {
  local value="$1"
  local color="$value"
  local alpha=""

  if [[ "$color" == *"@"* ]]; then
    alpha="@${color#*@}"
    color="${color%@*}"
  fi

  printf "0x%s%s\n" "$color" "$alpha"
}

resolve_font_file() {
  local font="$1"
  local resolved=""

  [[ -n "$font" ]] || return

  if [[ -f "$font" ]]; then
    resolve_path "$font"
    return
  fi

  if command -v fc-match >/dev/null 2>&1; then
    resolved="$(fc-match -f '%{file}\n' "$font" | head -n 1)"
    if [[ -n "$resolved" && -f "$resolved" ]]; then
      printf "%s\n" "$resolved"
      return
    fi
  fi

  die "Could not resolve font to a file: $font"
}

ensure_temp_dir() {
  if [[ -z "$TEMP_DIR" || ! -d "$TEMP_DIR" ]]; then
    TEMP_DIR="$(mktemp -d "${TMPDIR:-/tmp}/musiccloud-gource.XXXXXX")"
  fi
}

build_effective_gource_config() {
  local effective_config=""
  local needs_effective_config=0

  [[ -f "$CONFIG_FILE" ]] || die "Gource config not found: $CONFIG_FILE"

  if [[ "$GOURCE_VIEWPORT_SET" -eq 1 ||
    -n "$KEY_OVERRIDE" ||
    -n "$ANIMATION_FONT_FILE" ||
    -n "$ANIMATION_FONT_SIZE" ||
    -n "$ANIMATION_FONT_COLOR" ||
    -n "$ANIMATION_FILENAME_COLOR" ||
    -n "$ANIMATION_DIR_COLOR" ||
    -n "$ANIMATION_HIGHLIGHT_COLOR" ||
    -n "$ANIMATION_SELECTION_COLOR" ||
    "$ANIMATION_DATE_FORMAT_SET" -eq 1 ||
    -n "$ANIMATION_DATE_VISIBILITY" ||
    "$GOURCE_TITLE_OVERRIDE_SET" -eq 1 ]]; then
    needs_effective_config=1
  fi

  if [[ "$needs_effective_config" -eq 0 ]]; then
    printf "%s\n" "$CONFIG_FILE"
    return
  fi

  ensure_temp_dir
  effective_config="$TEMP_DIR/gource.conf"

  awk \
    -v viewport="$GOURCE_VIEWPORT" \
    -v viewport_set="$GOURCE_VIEWPORT_SET" \
    -v key="$KEY_OVERRIDE" \
    -v font_file="$ANIMATION_FONT_FILE" \
    -v font_size="$ANIMATION_FONT_SIZE" \
    -v font_colour="$ANIMATION_FONT_COLOR" \
    -v filename_colour="$ANIMATION_FILENAME_COLOR" \
    -v dir_colour="$ANIMATION_DIR_COLOR" \
    -v highlight_colour="$ANIMATION_HIGHLIGHT_COLOR" \
    -v selection_colour="$ANIMATION_SELECTION_COLOR" \
    -v date_format="$ANIMATION_DATE_FORMAT" \
    -v date_format_set="$ANIMATION_DATE_FORMAT_SET" \
    -v date_visibility="$ANIMATION_DATE_VISIBILITY" \
    -v title="$GOURCE_TITLE_OVERRIDE" \
    -v title_set="$GOURCE_TITLE_OVERRIDE_SET" '
    function trim(value) {
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", value);
      return value;
    }
    function has_display_override(name) {
      if (name == "viewport") return viewport_set == 1;
      return 0;
    }
    function display_override_value(name) {
      if (name == "viewport") return viewport;
      return "";
    }
    function print_display_override(name) {
      if (has_display_override(name) && !replaced_display[name]) {
        print name "=" display_override_value(name);
        replaced_display[name] = 1;
      }
    }
    function print_pending_display_overrides() {
      print_display_override("viewport");
    }
    function replace_display_if_needed(name) {
      pattern = "^[[:space:]]*" name "[[:space:]]*=";
      if ($0 ~ pattern) {
        if (has_display_override(name)) {
          if (!replaced_display[name]) {
            print name "=" display_override_value(name);
            replaced_display[name] = 1;
          }
          return 1;
        }
        return 0;
      }
      return 0;
    }
    function date_hide_value(current_value, parts, count, i, item, output, seen_date) {
      output = "";
      seen_date = 0;

      count = split(current_value, parts, ",");
      for (i = 1; i <= count; i++) {
        item = trim(parts[i]);
        if (item == "") continue;
        if (item == "date") {
          seen_date = 1;
          if (date_visibility == "show") continue;
        }
        if (output != "") output = output ",";
        output = output item;
      }

      if (date_visibility == "hide" && !seen_date) {
        if (output != "") output = output ",";
        output = output "date";
      }

      return output;
    }
    function print_hide_override(current_value, value) {
      if (date_visibility == "") return;
      value = date_hide_value(current_value);
      if (value != "") print "hide=" value;
      replaced["hide"] = 1;
    }
    function print_pending_hide_override() {
      if (date_visibility == "hide" && !replaced["hide"]) {
        print_hide_override("");
      }
    }
    function replace_hide_if_needed(current_value) {
      pattern = "^[[:space:]]*hide[[:space:]]*=";
      if ($0 ~ pattern) {
        if (date_visibility != "") {
          if (!replaced["hide"]) {
            current_value = $0;
            sub(/^[^=]*=/, "", current_value);
            print_hide_override(current_value);
          }
          return 1;
        }
        return 0;
      }
      return 0;
    }
    function has_override(name) {
      if (name == "key") return key != "";
      if (name == "font-file") return font_file != "";
      if (name == "font-size") return font_size != "";
      if (name == "font-colour") return font_colour != "";
      if (name == "filename-colour") return filename_colour != "";
      if (name == "dir-colour") return dir_colour != "";
      if (name == "highlight-colour") return highlight_colour != "";
      if (name == "selection-colour") return selection_colour != "";
      if (name == "date-format") return date_format_set == 1;
      if (name == "title") return title_set == 1 && title != "";
      return 0;
    }
    function override_value(name) {
      if (name == "key") return key;
      if (name == "font-file") return font_file;
      if (name == "font-size") return font_size;
      if (name == "font-colour") return font_colour;
      if (name == "filename-colour") return filename_colour;
      if (name == "dir-colour") return dir_colour;
      if (name == "highlight-colour") return highlight_colour;
      if (name == "selection-colour") return selection_colour;
      if (name == "date-format") return date_format;
      if (name == "title") return title;
      return "";
    }
    function print_override(name) {
      if (has_override(name) && !replaced[name]) {
        print name "=" override_value(name);
        replaced[name] = 1;
      }
    }
    function print_pending_overrides() {
      print_override("key");
      print_override("title");
      print_override("font-file");
      print_override("font-size");
      print_override("font-colour");
      print_override("filename-colour");
      print_override("dir-colour");
      print_override("highlight-colour");
      print_override("selection-colour");
      print_override("date-format");
      print_pending_hide_override();
    }
    function replace_if_needed(name) {
      pattern = "^[[:space:]]*" name "[[:space:]]*=";
      if ($0 ~ pattern) {
        if (name == "title" && title_set == 1 && title == "") {
          replaced[name] = 1;
          return 1;
        }
        if (has_override(name)) {
          if (!replaced[name]) {
            print name "=" override_value(name);
            replaced[name] = 1;
          }
          return 1;
        }
        return 0;
      }
      return 0;
    }
    BEGIN {
      in_display = 0;
      in_gource = 0;
    }
    /^\[.*\]$/ {
      if (in_display) {
        print_pending_display_overrides();
      }
      if (in_gource) {
        print_pending_overrides();
      }
      in_display = ($0 == "[display]");
      in_gource = ($0 == "[gource]");
      print;
      next;
    }
    in_display && replace_display_if_needed("viewport") {
      next;
    }
    in_gource && replace_hide_if_needed() {
      next;
    }
    in_gource && replace_if_needed("key") {
      next;
    }
    in_gource && replace_if_needed("title") {
      next;
    }
    in_gource && replace_if_needed("font-file") {
      next;
    }
    in_gource && replace_if_needed("font-size") {
      next;
    }
    in_gource && replace_if_needed("font-colour") {
      next;
    }
    in_gource && replace_if_needed("filename-colour") {
      next;
    }
    in_gource && replace_if_needed("dir-colour") {
      next;
    }
    in_gource && replace_if_needed("highlight-colour") {
      next;
    }
    in_gource && replace_if_needed("selection-colour") {
      next;
    }
    in_gource && replace_if_needed("date-format") {
      next;
    }
    {
      print;
    }
    END {
      if (in_display) {
        print_pending_display_overrides();
      }
      if (in_gource) {
        print_pending_overrides();
      }
    }
  ' "$CONFIG_FILE" > "$effective_config"

  printf "%s\n" "$effective_config"
}

parse_args() {
  while (($#)); do
    case "$1" in
      render)
        HLS_ONLY=0
        shift
        ;;
      hls)
        HLS_ONLY=1
        GENERATE_HLS=1
        shift
        ;;
      help)
        print_help
        exit 0
        ;;
      version)
        print_version
        exit 0
        ;;
      -h | --help)
        print_help
        exit 0
        ;;
      -V | --version)
        print_version
        exit 0
        ;;
      -c | --config)
        require_value "$1" "${2-}"
        CONFIG_FILE="$2"
        shift 2
        ;;
      -o | --output)
        require_value "$1" "${2-}"
        OUTPUT="$2"
        OUTPUT_SET=1
        shift 2
        ;;
      --viewport)
        require_value "$1" "${2-}"
        GOURCE_VIEWPORT="$(normalize_viewport "$2")"
        GOURCE_VIEWPORT_SET=1
        shift 2
        ;;
      --timezone | --tz)
        require_value "$1" "${2-}"
        RENDER_TZ="$2"
        shift 2
        ;;
      -a | --audio)
        require_value "$1" "${2-}"
        AUDIO="$2"
        USE_AUDIO=1
        shift 2
        ;;
      -N | --no-audio)
        USE_AUDIO=0
        AUDIO=""
        shift
        ;;
      -H | --hls)
        GENERATE_HLS=1
        shift
        ;;
      -L | --hls-only)
        HLS_ONLY=1
        GENERATE_HLS=1
        shift
        ;;
      -F | --from)
        require_value "$1" "${2-}"
        HLS_FROM="$2"
        HLS_ONLY=1
        GENERATE_HLS=1
        shift 2
        ;;
      -n | --no-hls)
        GENERATE_HLS=0
        shift
        ;;
      -O | --hls-output | -d | --hls-dir)
        require_value "$1" "${2-}"
        HLS_DIR="$2"
        shift 2
        ;;
      -t | --hls-time)
        require_value "$1" "${2-}"
        HLS_SEGMENT_SECONDS="$2"
        shift 2
        ;;
      -p | --poster-time)
        require_value "$1" "${2-}"
        POSTER_TIME_SECONDS="$2"
        shift 2
        ;;
      -K | --key | --legend)
        KEY_OVERRIDE="true"
        shift
        ;;
      --no-key | --no-legend)
        KEY_OVERRIDE="false"
        shift
        ;;
      -C | --crossfade)
        require_value "$1" "${2-}"
        AUDIO_CROSSFADE_SECONDS="$2"
        shift 2
        ;;
      -f | --fade)
        require_value "$1" "${2-}"
        AUDIO_FADE_IN_SECONDS="$2"
        AUDIO_FADE_OUT_SECONDS="$2"
        shift 2
        ;;
      --audio-fade-in)
        require_value "$1" "${2-}"
        AUDIO_FADE_IN_SECONDS="$2"
        shift 2
        ;;
      --audio-fade-out)
        require_value "$1" "${2-}"
        AUDIO_FADE_OUT_SECONDS="$2"
        shift 2
        ;;
      -v | --volume)
        require_value "$1" "${2-}"
        AUDIO_VOLUME="$2"
        shift 2
        ;;
      --duration | --video-duration)
        require_value "$1" "${2-}"
        RENDER_DURATION="$2"
        shift 2
        ;;
      --animation-font)
        require_value "$1" "${2-}"
        ANIMATION_FONT="$2"
        shift 2
        ;;
      --animation-font-size)
        require_value "$1" "${2-}"
        ANIMATION_FONT_SIZE="$2"
        shift 2
        ;;
      --animation-font-color | --animation-font-colour)
        require_value "$1" "${2-}"
        ANIMATION_FONT_COLOR="$2"
        shift 2
        ;;
      --animation-date-format | --date-format)
        require_value "$1" "${2-}"
        ANIMATION_DATE_FORMAT="$2"
        ANIMATION_DATE_FORMAT_SET=1
        shift 2
        ;;
      --animation-date | --show-animation-date | --show-date)
        ANIMATION_DATE_VISIBILITY="show"
        shift
        ;;
      --no-animation-date | --hide-animation-date | --hide-date)
        ANIMATION_DATE_VISIBILITY="hide"
        shift
        ;;
      --animation-date-font | --date-font)
        require_value "$1" "${2-}"
        ANIMATION_FONT="$2"
        shift 2
        ;;
      --animation-date-font-size | --date-font-size)
        require_value "$1" "${2-}"
        ANIMATION_FONT_SIZE="$2"
        shift 2
        ;;
      --animation-date-color | --animation-date-colour | --animation-date-font-color | \
        --animation-date-font-colour | --date-color | --date-colour | --date-font-color | --date-font-colour)
        require_value "$1" "${2-}"
        ANIMATION_FONT_COLOR="$2"
        shift 2
        ;;
      --animation-title | --gource-title)
        require_value "$1" "${2-}"
        GOURCE_TITLE_OVERRIDE="$2"
        GOURCE_TITLE_OVERRIDE_SET=1
        shift 2
        ;;
      --no-animation-title | --no-gource-title)
        GOURCE_TITLE_OVERRIDE=""
        GOURCE_TITLE_OVERRIDE_SET=1
        shift
        ;;
      --animation-title-font | --gource-title-font)
        require_value "$1" "${2-}"
        ANIMATION_FONT="$2"
        shift 2
        ;;
      --animation-title-font-size | --gource-title-font-size)
        require_value "$1" "${2-}"
        ANIMATION_FONT_SIZE="$2"
        shift 2
        ;;
      --animation-title-color | --animation-title-colour | --gource-title-color | --gource-title-colour)
        require_value "$1" "${2-}"
        ANIMATION_FONT_COLOR="$2"
        shift 2
        ;;
      --animation-filename-color | --animation-filename-colour)
        require_value "$1" "${2-}"
        ANIMATION_FILENAME_COLOR="$2"
        shift 2
        ;;
      --animation-dir-color | --animation-dir-colour)
        require_value "$1" "${2-}"
        ANIMATION_DIR_COLOR="$2"
        shift 2
        ;;
      --animation-highlight-color | --animation-highlight-colour)
        require_value "$1" "${2-}"
        ANIMATION_HIGHLIGHT_COLOR="$2"
        shift 2
        ;;
      --animation-selection-color | --animation-selection-colour)
        require_value "$1" "${2-}"
        ANIMATION_SELECTION_COLOR="$2"
        shift 2
        ;;
      --no-intro)
        INTRO_ENABLED=0
        shift
        ;;
      --intro)
        INTRO_ENABLED=1
        shift
        ;;
      --title | --intro-title)
        require_value "$1" "${2-}"
        INTRO_TITLE="$2"
        shift 2
        ;;
      --subtitle | --intro-subtitle)
        require_value "$1" "${2-}"
        INTRO_SUBTITLE="$2"
        shift 2
        ;;
      --title-font | --intro-title-font)
        require_value "$1" "${2-}"
        INTRO_TITLE_FONT="$2"
        shift 2
        ;;
      --subtitle-font | --intro-subtitle-font)
        require_value "$1" "${2-}"
        INTRO_SUBTITLE_FONT="$2"
        shift 2
        ;;
      --title-font-size | --intro-title-font-size)
        require_value "$1" "${2-}"
        INTRO_TITLE_FONT_SIZE="$2"
        shift 2
        ;;
      --subtitle-font-size | --intro-subtitle-font-size)
        require_value "$1" "${2-}"
        INTRO_SUBTITLE_FONT_SIZE="$2"
        shift 2
        ;;
      --title-color | --title-colour | --intro-title-color | --intro-title-colour)
        require_value "$1" "${2-}"
        INTRO_TITLE_COLOR="$2"
        shift 2
        ;;
      --subtitle-color | --subtitle-colour | --intro-subtitle-color | --intro-subtitle-colour)
        require_value "$1" "${2-}"
        INTRO_SUBTITLE_COLOR="$2"
        shift 2
        ;;
      --title-fade-in | --intro-title-fade-in)
        require_value "$1" "${2-}"
        INTRO_TITLE_FADE_IN="$2"
        shift 2
        ;;
      --subtitle-delay | --intro-subtitle-delay)
        require_value "$1" "${2-}"
        INTRO_SUBTITLE_DELAY="$2"
        shift 2
        ;;
      --subtitle-fade-in | --intro-subtitle-fade-in)
        require_value "$1" "${2-}"
        INTRO_SUBTITLE_FADE_IN="$2"
        shift 2
        ;;
      --intro-hold)
        require_value "$1" "${2-}"
        INTRO_HOLD="$2"
        shift 2
        ;;
      --intro-fade-out)
        require_value "$1" "${2-}"
        INTRO_TEXT_FADE_OUT="$2"
        shift 2
        ;;
      --intro-crossfade)
        require_value "$1" "${2-}"
        INTRO_CROSSFADE="$2"
        shift 2
        ;;
      --outro)
        OUTRO_ENABLED=1
        shift
        ;;
      --no-outro)
        OUTRO_ENABLED=0
        shift
        ;;
      --outro-title)
        require_value "$1" "${2-}"
        OUTRO_TITLE="$2"
        OUTRO_ENABLED=1
        shift 2
        ;;
      --outro-subtitle)
        require_value "$1" "${2-}"
        OUTRO_SUBTITLE="$2"
        OUTRO_ENABLED=1
        shift 2
        ;;
      --outro-title-font)
        require_value "$1" "${2-}"
        OUTRO_TITLE_FONT="$2"
        shift 2
        ;;
      --outro-subtitle-font)
        require_value "$1" "${2-}"
        OUTRO_SUBTITLE_FONT="$2"
        shift 2
        ;;
      --outro-title-font-size)
        require_value "$1" "${2-}"
        OUTRO_TITLE_FONT_SIZE="$2"
        shift 2
        ;;
      --outro-subtitle-font-size)
        require_value "$1" "${2-}"
        OUTRO_SUBTITLE_FONT_SIZE="$2"
        shift 2
        ;;
      --outro-title-color | --outro-title-colour)
        require_value "$1" "${2-}"
        OUTRO_TITLE_COLOR="$2"
        shift 2
        ;;
      --outro-subtitle-color | --outro-subtitle-colour)
        require_value "$1" "${2-}"
        OUTRO_SUBTITLE_COLOR="$2"
        shift 2
        ;;
      --outro-title-fade-in)
        require_value "$1" "${2-}"
        OUTRO_TITLE_FADE_IN="$2"
        shift 2
        ;;
      --outro-subtitle-delay)
        require_value "$1" "${2-}"
        OUTRO_SUBTITLE_DELAY="$2"
        shift 2
        ;;
      --outro-subtitle-fade-in)
        require_value "$1" "${2-}"
        OUTRO_SUBTITLE_FADE_IN="$2"
        shift 2
        ;;
      --outro-hold)
        require_value "$1" "${2-}"
        OUTRO_HOLD="$2"
        shift 2
        ;;
      --outro-fade-out)
        require_value "$1" "${2-}"
        OUTRO_TEXT_FADE_OUT="$2"
        shift 2
        ;;
      --outro-crossfade)
        require_value "$1" "${2-}"
        OUTRO_CROSSFADE="$2"
        shift 2
        ;;
      -G | --gource-bin)
        require_value "$1" "${2-}"
        GOURCE_BIN="$2"
