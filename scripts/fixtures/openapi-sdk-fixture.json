{
  "openapi": "3.1.0",
  "info": {
    "title": "musiccloud SDK Fixture API",
    "version": "2.1.0"
  },
  "paths": {
    "/api/v1/resolve": {
      "post": {
        "operationId": "resolveTrack",
        "tags": ["Resolve"],
        "summary": "Resolve a track",
        "security": [{ "ApiKeyAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ResolveRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Resolved links.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ResolveResponse" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    },
    "schemas": {
      "ResolveRequest": {
        "type": "object",
        "required": ["url"],
        "properties": {
          "url": { "type": "string", "format": "uri" }
        }
      },
      "ResolveResponse": {
        "type": "object",
        "required": ["links"],
        "properties": {
          "links": {
            "type": "array",
            "items": { "type": "string", "format": "uri" }
          }
        }
      }
    }
  }
}
