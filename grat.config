version = 1

[project]
name = 'musiccloud.io'

[runtime]
start_timeout = '60s'
probe_interval = '250ms'
health_timeout = '2s'
shutdown_timeout = '10s'
log_tail_lines = 20

[[services]]
name = 'shared'
command = 'pnpm dev:shared'
role = 'worker'
port = 0
host = 'localhost'
health_path = ''

[[services]]
name = 'backend'
command = 'pnpm dev:backend'
role = 'backend'
port = 4001
host = 'localhost'
health_path = '/health/backend'

[[services]]
name = 'frontend'
command = 'pnpm dev'
role = 'frontend'
port = 3001
host = 'localhost'
health_path = '/'

[[services]]
name = 'developer'
command = 'pnpm dev:developer'
role = 'developer'
port = 3100
host = 'localhost'
health_path = '/'

[[services]]
name = 'dashboard'
command = 'pnpm dev:dashboard'
role = 'dashboard'
port = 4501
host = 'localhost'
health_path = '/'
