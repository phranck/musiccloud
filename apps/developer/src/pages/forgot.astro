---
/**
 * /forgot — password-reset request page.
 *
 * Renders the {@link ForgotForm} island, which posts an email to
 * `request-reset` and always shows a neutral confirmation (no account-existence
 * leak). A footer link returns to sign-in.
 */
import AuthCard from "@/components/auth/AuthCard.astro";
import { ForgotForm } from "@/components/auth/ForgotForm";
import BaseLayout from "@/layouts/BaseLayout.astro";

export const prerender = false;
---

<BaseLayout title="Reset password · musiccloud for developers">
  <AuthCard title="Reset password">
    <Fragment slot="subtitle">Enter your account email and we'll send you a reset link.</Fragment>
    <ForgotForm client:load />
    <Fragment slot="footer">
      <a href="/login" class="text-fg text-link">Back to sign in</a>
    </Fragment>
  </AuthCard>
</BaseLayout>
