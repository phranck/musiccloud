---
/**
 * /signup: the developer-portal account creation page.
 *
 * Server-side: an already-authenticated developer is redirected to the
 * dashboard. Layout per spec: the GitHub button first, an "or" divider, then the
 * signup island, a Terms/Privacy consent line, and a footer link to sign-in. The
 * GitHub button and divider are passed as children of the signup island so that,
 * once the form succeeds, they are hidden together with the form and only the
 * "check your email" panel remains.
 * Submitting the form does not create a session; the developer must verify by
 * email and then sign in.
 *
 * A `?tier=<id>` query param (the pricing page's Subscribe flow, MC-101) is
 * required: missing, disabled, or non-assignable tiers redirect to /pricing.
 * Only the free tier (`tier_free`) is selectable until billing lands; this
 * mirrors the backend's `resolveSignupTierId` invariant.
 */
import AuthCard from "@/components/auth/AuthCard.astro";
import GitHubButton from "@/components/auth/GitHubButton.astro";
import OrDivider from "@/components/auth/OrDivider.astro";
import { SignupForm } from "@/components/auth/SignupForm";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { backendUrl } from "@/lib/api";
import { getDeveloperSession } from "@/lib/session";
import { ENDPOINTS } from "@musiccloud/shared";

export const prerender = false;

const account = await getDeveloperSession(Astro);
if (account) return Astro.redirect("/dashboard");

interface SelectedTier {
  id: string;
  name: string;
  color: string;
}

const tierParam = Astro.url.searchParams.get("tier");

// Gate: a tier param must be present, resolve to an enabled tier, and be
// assignable in this phase. Only tier_free is assignable until billing lands;
// this mirrors the backend's resolveSignupTierId invariant. On any failure
// (missing param, disabled/unknown tier, unreachable backend) we redirect to
// /pricing rather than rendering a tier-less signup form.
let selectedTier: SelectedTier | null = null;
if (tierParam) {
  try {
    const res = await fetch(backendUrl(ENDPOINTS.v1.tiers));
    if (res.ok) {
      const tiers = (await res.json()) as (SelectedTier & { enabled: boolean })[];
      const tier = tiers.find((t) => t.id === tierParam && t.enabled);
      // Only the free tier is assignable until paid billing lands.
      if (tier && tier.id === "tier_free") {
        selectedTier = { id: tier.id, name: tier.name, color: tier.color };
      }
    }
  } catch {
    // The backend is unreachable. Fail safe: redirect to /pricing below.
  }
}

if (!selectedTier) return Astro.redirect("/pricing");
---

<BaseLayout title="Create account · musiccloud for developers">
  <AuthCard title="Create your developer account">
    <SignupForm client:load tier={selectedTier ?? undefined}>
      <GitHubButton intent="signup" />
      <OrDivider />
    </SignupForm>
    <p class="text-body text-fg-subtle text-center mt-5">
      By creating an account you agree to our{" "}
      <a href="/terms" class="content-link text-fg-muted">Terms</a> and{" "}
      <a href="/privacy" class="content-link text-fg-muted">Privacy Policy</a>.
    </p>
    <Fragment slot="footer">
      Already have an account? <a href="/login" class="content-link text-fg">Sign in</a>
    </Fragment>
  </AuthCard>
</BaseLayout>
