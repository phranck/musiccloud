---
/**
 * /terms: the developer-portal Terms of Service placeholder.
 *
 * Honest, minimal page that removes the live 404 the landing footer and the
 * signup consent line link to. It deliberately contains NO binding legal text:
 * the full Terms are finalised by the operator before public API launch. Only a
 * heading and a factual placeholder paragraph.
 *
 * English-only, BaseLayout-based, fully token-driven (glassy surface,
 * brand-blue accents, shared header/footer shell matching /docs). Rendered
 * server-side: the shared `PublicHeader` resolves the developer session for
 * the avatar menu. No `useT`/`useLocale`.
 */
import PublicHeader from "@/components/PublicHeader.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import PublicFooter from "@/components/PublicFooter.astro";
import { ScrollIcon } from "@/lib/icons";
import { getDeveloperSession } from "@/lib/session";

const account = await getDeveloperSession(Astro);
---

<BaseLayout
  title="Terms of Service · musiccloud for developers"
  description="The musiccloud developer Terms of Service."
>
  <PublicHeader account={account} />

  <main class="developer-shell developer-page flex-1">
    <div class="page-heading">
      <ScrollIcon className="page-heading__icon" aria-hidden="true" />
      <h1 class="page-heading__title">Terms of Service</h1>
    </div>

    <section class="surface-card px-7 py-7 mb-8">
      <p class="text-body text-fg-muted">
        The full Terms of Service for the musiccloud developer portal and API are being finalised and will
        be published here before public API access opens. Until then, this page is a placeholder.
      </p>
    </section>

  </main>

  <PublicFooter />
</BaseLayout>
