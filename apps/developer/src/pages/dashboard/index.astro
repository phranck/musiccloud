---
/**
 * /dashboard — the signed-in developer overview (protected).
 *
 * Server-side: resolves the `mc_dev_session` cookie via `getDeveloperSession`;
 * without a valid session the request is redirected to `/login` before any
 * markup renders. With a session it renders the dashboard shell with the
 * Overview tab active: a greeting, an account-summary card (email, plan,
 * verification status, member-since), and a placeholder pointing at the
 * not-yet-built API-access flow.
 */
import { CheckCircleIcon, WarningCircleIcon } from "@phosphor-icons/react";
import DashboardLayout from "@/components/dashboard/DashboardLayout.astro";
import { DashboardTab } from "@/lib/dashboardTabs";
import { getDeveloperSession } from "@/lib/session";

export const prerender = false;

const account = await getDeveloperSession(Astro);
if (!account) return Astro.redirect("/login");

const greetingName = account.displayName?.trim() || account.email;
const planLabel = account.plan.charAt(0).toUpperCase() + account.plan.slice(1);
const memberSince = new Date(account.createdAt).toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<DashboardLayout account={account} active={DashboardTab.Overview} title="Dashboard · musiccloud for developers">
  <h1 class="text-card-title font-medium tracking-tight mb-1">Welcome back, {greetingName}</h1>
  <p class="text-body text-fg-muted mb-7">Here is your developer account at a glance.</p>

  <section class="rounded-card border border-border bg-surface px-6 py-5 mb-6">
    <h2 class="text-body font-medium text-fg mb-4">Account</h2>
    <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-4">
      <div>
        <dt class="text-nav text-fg-subtle mb-0.5">Email</dt>
        <dd class="text-body text-fg flex items-center gap-1.5">
          {account.email}
          {
            account.emailVerified ? (
              <CheckCircleIcon weight="duotone" className="size-4 text-accent" aria-label="Verified" />
            ) : (
              <WarningCircleIcon weight="duotone" className="size-4 text-gold" aria-label="Not verified" />
            )
          }
        </dd>
      </div>
      <div>
        <dt class="text-nav text-fg-subtle mb-0.5">Plan</dt>
        <dd class="text-body text-fg">{planLabel}</dd>
      </div>
      <div>
        <dt class="text-nav text-fg-subtle mb-0.5">Email status</dt>
        <dd class="text-body text-fg">{account.emailVerified ? "Verified" : "Not verified"}</dd>
      </div>
      <div>
        <dt class="text-nav text-fg-subtle mb-0.5">Member since</dt>
        <dd class="text-body text-fg">{memberSince}</dd>
      </div>
    </dl>
  </section>

  <section class="rounded-card border border-border bg-surface px-6 py-5">
    <h2 class="text-body font-medium text-fg mb-1">Get started</h2>
    <p class="text-body text-fg-muted">
      Request API access to receive a key and start calling the musiccloud API. This flow is coming soon.
    </p>
  </section>
</DashboardLayout>
