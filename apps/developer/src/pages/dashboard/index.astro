---
/**
 * /dashboard: the signed-in developer overview (protected).
 *
 * Server-side: resolves the `mc_dev_session` cookie via `getDeveloperSession`;
 * without a valid session the request is redirected to `/login` before any
 * markup renders. With a session it renders the dashboard shell with the
 * Overview tab active: a greeting, an account-summary card (email, plan with
 * a pricing-commitment link, verification status, member-since), a
 * get-started card linking to the API-access flow, and a Danger Zone card
 * for self-service account deletion.
 */
import DashboardLayout from "@/components/dashboard/DashboardLayout.astro";
import { DeleteAccountSection } from "@/components/dashboard/DeleteAccountSection";
import { DashboardTab } from "@/lib/dashboardTabs";
import { TickCircleIcon, Warning2Icon } from "@/lib/icons";
import { getDeveloperSession } from "@/lib/session";

export const prerender = false;

const account = await getDeveloperSession(Astro);
if (!account) return Astro.redirect("/login");
// Defense-in-depth: after the backfill migration no account should be tier-less;
// this catches any future tier-less path (e.g. a race before tier assignment).
if (account.tierName == null) return Astro.redirect("/pricing");

const greetingName = account.displayName?.trim() || account.email;
const planLabel = account.tierName ?? "None";
const memberSince = new Date(account.createdAt).toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<DashboardLayout account={account} active={DashboardTab.Overview} title="Dashboard · musiccloud for developers">
  <h1 class="card-content-inset text-hero font-medium tracking-tight mb-1">Welcome back, {greetingName}</h1>
  <p class="card-content-inset text-body text-fg-muted mb-7">Here is your developer account at a glance.</p>

  <section class="mb-6">
    <h2 class="card-content-inset text-card-title font-medium tracking-tight mb-3">Account</h2>
    <dl class="surface-card px-6 py-5 grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-4">
      <div>
        <dt class="text-nav text-fg-subtle mb-0.5">Email</dt>
        <dd class="text-body text-fg flex items-center gap-1.5">
          {account.email}
          {
            account.emailVerified ? (
              <TickCircleIcon className="size-4 text-accent" aria-label="Verified" />
            ) : (
              <Warning2Icon className="size-4 text-gold" aria-label="Not verified" />
            )
          }
        </dd>
      </div>
      <div>
        <dt class="text-nav text-fg-subtle mb-0.5">Plan</dt>
        <dd class="text-body text-fg">
          {planLabel}
          <a href="/pricing" class="content-link text-nav text-fg-muted ml-2">see our pricing commitment</a>
        </dd>
      </div>
      <div>
        <dt class="text-nav text-fg-subtle mb-0.5">Email status</dt>
        <dd class="text-body text-fg">{account.emailVerified ? "Verified" : "Not verified"}</dd>
      </div>
      <div>
        <dt class="text-nav text-fg-subtle mb-0.5">Member since</dt>
        <dd class="text-body text-fg">{memberSince}</dd>
      </div>
    </dl>
  </section>

  <section class="mb-6">
    <h2 class="card-content-inset text-card-title font-medium tracking-tight mb-3">Get started</h2>
    <div class="surface-card px-6 py-5">
      <p class="text-body text-fg-muted mb-4">
        Request API access to receive a key and start calling the musiccloud API.
      </p>
      <a
        href="/dashboard/api-access"
        class="button button--primary text-body"
      >
        Request API access
      </a>
    </div>
  </section>

  <DeleteAccountSection client:load hasPassword={account.hasPassword} />
</DashboardLayout>
