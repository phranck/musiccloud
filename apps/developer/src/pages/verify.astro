---
/**
 * /verify?token=… — email-verification landing page.
 *
 * Reads the token from the query string. Without one it shows a static error
 * (the link was malformed). With a token it mounts the {@link VerifyView}
 * island, which auto-submits the verification on load and reports the outcome.
 */
import AuthCard from "@/components/auth/AuthCard.astro";
import { VerifyView } from "@/components/auth/VerifyView";
import BaseLayout from "@/layouts/BaseLayout.astro";

export const prerender = false;

const token = Astro.url.searchParams.get("token");
---

<BaseLayout title="Verify email · musiccloud for developers">
  <AuthCard title="Verify email">
    {
      token ? (
        <VerifyView client:load token={token} />
      ) : (
        <p class="text-body text-fg-muted text-center py-2">
          This verification link is missing its token. Please use the link from your email.
        </p>
      )
    }
    <Fragment slot="footer">
      <a href="/login" class="text-fg text-link">Back to sign in</a>
    </Fragment>
  </AuthCard>
</BaseLayout>
