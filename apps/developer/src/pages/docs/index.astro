---
/**
 * /docs: the developer-portal documentation landing page.
 *
 * Static, English-only marketing-grade overview of what the musiccloud API
 * does and how a developer gets from zero to their first call. It mirrors the
 * landing page's token-driven night-mode styling (glassy `bg-surface` sections
 * over the night-sky gradient, brand-blue `--color-accent` accents, Iconsax
 * TwoTone icons via `@/lib/icons`) and the same header/footer shell so the
 * portal reads as one coherent site.
 *
 * Rendered server-side: the shared `PublicHeader` resolves the developer
 * session so a signed-in visitor sees their avatar menu instead of
 * Log in/Sign up. It carries no `useT`/`useLocale`; all copy is hard-coded
 * EN, matching the rest of the developer portal.
 */
import PublicHeader from "@/components/PublicHeader.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import PublicFooter from "@/components/PublicFooter.astro";
import { BookIcon, FlashIcon, KeyIcon, LinkIcon, ProfileAddIcon } from "@/lib/icons";
import { getDeveloperSession } from "@/lib/session";

const account = await getDeveloperSession(Astro);

/**
 * The four ordered steps that take a developer from no account to their first
 * authenticated API call. Each step is rendered as a numbered glassy row.
 */
const steps = [
  {
    Icon: ProfileAddIcon,
    title: "Create a developer account",
    body: "Sign up with your email or GitHub to get a developer account on the portal.",
  },
  {
    Icon: FlashIcon,
    title: "Request API access",
    body: "From your dashboard, request access to the musiccloud API for your account.",
  },
  {
    Icon: KeyIcon,
    title: "Receive an API key",
    body: "Once access is granted, an API key is issued to your account for authenticating requests.",
  },
  {
    Icon: LinkIcon,
    title: "Call the API",
    body: "Send your key in the request header and start resolving links and fetching artist info.",
  },
];

---

<BaseLayout
  title="Documentation · musiccloud for developers"
  description="How the musiccloud API works and how to get started building with it."
>
  <PublicHeader account={account} active="docs" />

  <main class="flex-1 max-w-6xl mx-auto w-full px-6 pt-12 pb-20">
    <div class="flex items-center gap-3 mb-5">
      <BookIcon className="size-9 text-accent" aria-hidden="true" />
      <h1 class="text-hero font-medium tracking-tight leading-none">Documentation</h1>
    </div>
    <p class="text-lead text-fg-muted mb-10">
      The musiccloud API turns a single music link into every platform. Resolve a track or album from one
      streaming service to its matches across the others, pull rich artist info, and explore a free-to-use
      Creative Commons catalogue. All of it runs over one REST API.
    </p>

    <section class="rounded-card border border-border bg-surface px-7 py-7 mb-6">
      <h2 class="text-card-title font-medium tracking-tight mb-2">What you can build</h2>
      <p class="text-body text-fg-muted mb-5">
        One key gives you three capabilities, each a JSON REST endpoint:
      </p>
      <ul class="grid grid-cols-1 gap-3">
        <li class="flex items-start gap-3">
          <LinkIcon className="size-6 text-accent shrink-0 mt-0.5" aria-hidden="true" />
          <span class="text-body text-fg-muted">
            <span class="text-fg font-medium">Link resolve.</span> Match a track, album, or artist from one
            streaming service to the same release everywhere else.
          </span>
        </li>
        <li class="flex items-start gap-3">
          <BookIcon className="size-6 text-accent shrink-0 mt-0.5" aria-hidden="true" />
          <span class="text-body text-fg-muted">
            <span class="text-fg font-medium">Artist info.</span> Top tracks, similar artists, and upcoming
            events for any matched artist.
          </span>
        </li>
        <li class="flex items-start gap-3">
          <KeyIcon className="size-6 text-accent shrink-0 mt-0.5" aria-hidden="true" />
          <span class="text-body text-fg-muted">
            <span class="text-fg font-medium">Creative Commons.</span> Search and resolve the free-to-use
            Jamendo catalogue for tracks you can use openly.
          </span>
        </li>
      </ul>
    </section>

    <section class="rounded-card border border-border bg-surface px-7 py-7 mb-6">
      <h2 class="text-card-title font-medium tracking-tight mb-2">Getting started</h2>
      <p class="text-body text-fg-muted mb-6">Four steps take you from zero to your first call.</p>
      <ol class="grid grid-cols-1 gap-4">
        {
          steps.map((step, index) => {
            const Icon = step.Icon;
            return (
              <li class="flex items-start gap-4">
                <span class="flex items-center justify-center size-9 shrink-0 rounded-button border border-border-strong text-nav font-medium text-accent">
                  {index + 1}
                </span>
                <div>
                  <div class="flex items-center gap-2 mb-0.5">
                    <Icon className="size-5 text-accent" aria-hidden="true" />
                    <h3 class="text-body font-medium text-fg">{step.title}</h3>
                  </div>
                  <p class="text-body text-fg-muted">{step.body}</p>
                </div>
              </li>
            );
          })
        }
      </ol>
      <p class="text-body text-fg-subtle mt-6">
        The whole flow is self-service: request access, receive your key, and manage it, all from{" "}
        <a href="/dashboard" class="text-fg text-link">your dashboard</a>. The API is free while we build it
        out; see <a href="/pricing" class="text-fg text-link">pricing</a> for our written commitment.
      </p>
    </section>

    <div class="flex flex-wrap gap-3">
      <a
        href="/docs/api"
        class="inline-flex items-center gap-2 rounded-button bg-accent text-on-accent px-5 py-2.5 text-body font-medium"
      >
        <BookIcon className="size-6" aria-hidden="true" />
        API reference
      </a>
      <a
        href="/signup"
        class="inline-flex items-center gap-2 rounded-button border border-border-strong px-5 py-2.5 text-body font-medium"
      >
        <KeyIcon className="size-6" aria-hidden="true" />
        Create an account
      </a>
    </div>
  </main>

  <PublicFooter />
</BaseLayout>
