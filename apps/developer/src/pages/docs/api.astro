---
import PublicHeader from "@/components/PublicHeader.astro";
import ApiReferenceContent from "@/components/docs/ApiReferenceContent.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import PublicFooter from "@/components/PublicFooter.astro";
import openApiDocument from "@/generated/openapi.json";
import openApiMetadata from "@/generated/openapi.metadata.json";
import sdkCatalogJson from "@/generated/sdk-catalog.json";
import { buildApiReference } from "@/lib/openapi-reference";
import { parseSdkCatalog } from "@/lib/sdk-catalog";
import { getDeveloperSession } from "@/lib/session";
import "../../styles/docs.css";

const account = await getDeveloperSession(Astro);
const reference = buildApiReference(openApiDocument);
const catalog = parseSdkCatalog(sdkCatalogJson, {
  version: openApiMetadata.version,
  sha256: openApiMetadata.sha256,
}, {
  // A local dev server may preview OpenAPI documentation before its matching
  // versioned SDK archives are published. Production builds remain strict.
  allowStaleOpenApiFingerprint: import.meta.env.DEV,
});

---

<BaseLayout
  title="API reference · musiccloud for developers"
  description="The musiccloud API at a glance: base URL, API-key authentication, and JSON responses."
>
  <PublicHeader account={account} active="api" />

  <main class="developer-shell developer-page flex-1">
    <ApiReferenceContent reference={reference} catalog={catalog} />
  </main>

  <PublicFooter />
</BaseLayout>
