---
/**
 * /login: the developer-portal sign-in page.
 *
 * Server-side: if a valid `mc_dev_session` already resolves an account, the
 * developer is redirected straight to the dashboard. A `?error=oauth` query
 * (set by the GitHub OAuth callback on CSRF/exchange failure) renders an inline
 * notice. Layout per spec: the GitHub button first, an "or" divider, then the
 * email/password island, a "Forgot password?" link (inside the form), and a
 * footer link to signup.
 */
import AuthCard from "@/components/auth/AuthCard.astro";
import GitHubButton from "@/components/auth/GitHubButton.astro";
import { LoginForm } from "@/components/auth/LoginForm";
import OrDivider from "@/components/auth/OrDivider.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getDeveloperSession } from "@/lib/session";

export const prerender = false;

const account = await getDeveloperSession(Astro);
if (account) return Astro.redirect("/dashboard");

const oauthFailed = Astro.url.searchParams.get("error") === "oauth";
---

<BaseLayout title="Sign in · musiccloud for developers">
  <AuthCard title="Sign in">
    {
      oauthFailed && (
        <div class="status-message status-message--danger mb-5">
          GitHub sign-in could not be completed. Please try again.
        </div>
      )
    }
    <GitHubButton intent="login" />
    <OrDivider />
    <LoginForm client:load />
    <Fragment slot="footer">
      No account? <a href="/signup" class="content-link text-fg">Sign up</a>
    </Fragment>
  </AuthCard>
</BaseLayout>
