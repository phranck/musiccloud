---
/**
 * OrDivider — the "or" separator between the GitHub button and the
 * email/password form on the login and signup screens. A centred lowercase
 * label flanked by two hairline rules drawn from `--color-border`.
 */
---

<div class="flex items-center gap-3 my-5" role="separator" aria-label="or">
  <span class="h-px flex-1 bg-border"></span>
  <span class="text-body text-fg-subtle">or</span>
  <span class="h-px flex-1 bg-border"></span>
</div>
