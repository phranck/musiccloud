---
/**
 * PublicFooter is the shared bottom bar of every public developer-portal page
 * (landing, docs, API reference, pricing, terms, privacy). Replaces the
 * per-page duplicated footer markup, mirroring `PublicHeader`.
 *
 * Copyright on the left, the shared `FOOTER_LINKS` on the right. Text sits in
 * muted foreground (not the darker subtle tone) so it stays comfortably
 * legible over the night-sky gradient.
 */
import type { DeveloperPortalNavigationItem } from "@musiccloud/shared";
import { NavigationArea } from "@musiccloud/shared";
import { getDeveloperPortalNavigation } from "@/lib/editorial";

interface Props {
  /** Explicit managed data for isolated rendering; normal SSR loads Footer. */
  navigation?: readonly DeveloperPortalNavigationItem[];
}

const { navigation: suppliedNavigation } = Astro.props;
const navigation = suppliedNavigation ?? (await getDeveloperPortalNavigation(NavigationArea.Footer));
---

<footer class="public-footer">
  <div class="public-footer__inner developer-shell">
    <span>© musiccloud</span>
    <nav class="public-footer__navigation" aria-label="Footer">
      {
        navigation.map((link) => {
          const isExternal = link.target === "_blank";
          return (
            <a
              href={link.href}
              target={isExternal ? "_blank" : undefined}
              rel={isExternal ? "noopener noreferrer" : undefined}
              class="content-link"
              data-public-search-command={link.behavior === "open-api-search" ? "true" : undefined}
            >
              {link.label}
            </a>
          );
        })
      }
    </nav>
  </div>
</footer>
