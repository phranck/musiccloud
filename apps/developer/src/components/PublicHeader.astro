---
/**
 * PublicHeader is the shared top bar of every public developer-portal page
 * (landing, docs, API reference, pricing, terms, privacy). Replaces the
 * previously per-page duplicated header markup (MC-102).
 *
 * Signed out it offers "Sign in" only; sign-up happens exclusively through
 * picking a tier on /pricing (the Subscribe flow, MC-101), so the header
 * carries no sign-up entry. Signed in, "Sign in" disappears and the account's
 * avatar (with the Dashboard/Logout menu, see `AvatarMenu`) sits at the far
 * right, after the nav links. The nav itself is identical in both states:
 * Docs, API reference, Pricing and the global API Search command. Status
 * lives in the footer only.
 */
import { AvatarMenu } from "@/components/portal/AvatarMenu";
import { KeyCap } from "@/components/KeyCap";
import Wordmark from "@/components/Wordmark.astro";
import { LoginIcon, MenuIcon } from "@/lib/icons";
import { PUBLIC_NAV_ITEMS, PUBLIC_SEARCH_COMMAND, type PublicNavigationId } from "@/lib/publicNavigation";
import type { Account } from "@/lib/session";

interface Props {
  /** The signed-in account (drives the avatar menu), or `null` when signed out. */
  account: Account | null;
  /** The nav entry to highlight as the current page, if any. */
  active?: PublicNavigationId;
}

const { account, active } = Astro.props;

/** Nav link classes: the active page gets full-strength text. */
const navClass = (id: PublicNavigationId) =>
  active === id ? "public-navigation__link public-navigation__link--active" : "public-navigation__link";
const SearchIcon = PUBLIC_SEARCH_COMMAND.icon;
---

<div class="public-header">
<header class="public-header__inner developer-shell">
  <Wordmark />
  <div class="public-header__actions">
    <nav class="public-header__desktop" aria-label="Primary" data-public-navigation="desktop">
      {
        PUBLIC_NAV_ITEMS.map((item) => (
          (() => {
            const Icon = item.icon;
            return (
              <a href={item.href} aria-current={active === item.id ? "page" : undefined} class={navClass(item.id)}>
                <Icon className="public-navigation__item-icon" aria-hidden="true" />
                <span class="public-navigation__label">{item.label}</span>
              </a>
            );
          })()
        ))
      }
      <a href={PUBLIC_SEARCH_COMMAND.href} class="public-navigation__link" data-public-search-command>
        <SearchIcon className="public-navigation__item-icon" aria-hidden="true" />
        <span class="public-navigation__label">{PUBLIC_SEARCH_COMMAND.label}</span>
        <KeyCap shortcut={PUBLIC_SEARCH_COMMAND.shortcut} />
      </a>
      {
        !account && (
          <a href="/login" class="public-navigation__link">
            <LoginIcon className="public-navigation__item-icon" aria-hidden="true" />
            <span class="public-navigation__label">Sign in</span>
          </a>
        )
      }
    </nav>

    {
      account && (
        <AvatarMenu
          client:load
          account={{ email: account.email, displayName: account.displayName, avatarUrl: account.avatarUrl }}
        />
      )
    }

    <details class="public-header__mobile" data-public-navigation="mobile">
      <summary class="button button--icon public-header__mobile-trigger" aria-label="Open navigation">
        <MenuIcon className="size-6" aria-hidden="true" />
      </summary>
      <nav class="public-header__mobile-panel" aria-label="Mobile primary">
        {
          PUBLIC_NAV_ITEMS.map((item) => (
            (() => {
              const Icon = item.icon;
              return (
                <a href={item.href} aria-current={active === item.id ? "page" : undefined} class={navClass(item.id)}>
                  <Icon className="public-navigation__item-icon" aria-hidden="true" />
                  <span class="public-navigation__label">{item.label}</span>
                </a>
              );
            })()
          ))
        }
        <a href={PUBLIC_SEARCH_COMMAND.href} class="public-navigation__link" data-public-search-command>
          <SearchIcon className="public-navigation__item-icon" aria-hidden="true" />
          <span class="public-navigation__label">{PUBLIC_SEARCH_COMMAND.label}</span>
          <KeyCap shortcut={PUBLIC_SEARCH_COMMAND.shortcut} />
        </a>
        {
          !account && (
            <a href="/login" class="public-navigation__link">
              <LoginIcon className="public-navigation__item-icon" aria-hidden="true" />
              <span class="public-navigation__label">Sign in</span>
            </a>
          )
        }
      </nav>
    </details>
  </div>
</header>
</div>

<script>
  const searchHref = "/docs/api?search=1";
  const isApiReference = () => window.location.pathname === "/docs/api";
  const apiSearchWindow = window as Window & { musiccloudApiSearchOpen?: () => void };

  /** Records API-page requests until the controller has hydrated, avoiding a
      reload when a user invokes Search before the React island is ready. */
  const requestApiSearch = () => {
    if (isApiReference()) {
      document.documentElement.dataset.apiSearchRequested = "true";
      if (apiSearchWindow.musiccloudApiSearchOpen) {
        apiSearchWindow.musiccloudApiSearchOpen();
      } else if (document.documentElement.dataset.apiSearchReady === "true") {
        window.dispatchEvent(new CustomEvent("musiccloud:api-search-open"));
      }
      return;
    }
    window.location.assign(searchHref);
  };

  document.addEventListener("click", (event) => {
    const command = event.target instanceof Element ? event.target.closest("[data-public-search-command]") : null;
    if (!command) return;
    event.preventDefault();
    requestApiSearch();
  });

  document.addEventListener("keydown", (event) => {
    if (!(event.metaKey || event.ctrlKey) || event.key.toLocaleLowerCase() !== "k") return;
    event.preventDefault();
    requestApiSearch();
  });
</script>
