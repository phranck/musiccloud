---
/**
 * Generated API reference content composed from normalized chapter, entry,
 * card, and panel compounds.
 *
 * `buildApiReference` and `parseSdkCatalog` validate all data before it reaches
 * this layout-only component.
 */
import { ApiContent } from "@/components/docs/ApiContent";
import { ApiDocumentSearch } from "@/components/docs/ApiDocumentSearch";
import ApiReferenceNav from "@/components/docs/ApiReferenceNav.astro";
import CodeBlock from "@/components/docs/CodeBlock.astro";
import { ContentCard } from "@/components/docs/ContentCard";
import { ContentPanel } from "@/components/docs/ContentPanel";
import EndpointOperation from "@/components/docs/EndpointOperation.astro";
import SchemaSection from "@/components/docs/SchemaSection.astro";
import SchemaCardsController from "@/components/docs/SchemaCardsController.astro";
import ScrollToTopButton from "@/components/docs/ScrollToTopButton.astro";
import SdkSegmentedCard from "@/components/docs/SdkSegmentedCard.astro";
import { ArrowCircleDownIcon, ArrowCircleUpIcon } from "@/lib/icons";
import {
  apiReferenceSectionLabel,
  apiReferenceStaticSectionIcons,
  iconForApiReferenceSection,
} from "@/lib/api-reference-section-icons";
import type { ApiReference } from "@/lib/openapi-reference";
import type { SdkCatalog } from "@/lib/sdk-catalog";

interface Props {
  reference: ApiReference;
  catalog: SdkCatalog;
}

const { reference, catalog } = Astro.props;
const IntegrationIcon = apiReferenceStaticSectionIcons.integration;
const SdkIcon = apiReferenceStaticSectionIcons.sdk;
const SchemasIcon = apiReferenceStaticSectionIcons.schemas;

const integrationItems = [
  ["Authentication", "Send X-API-Key with your mc_live key. Never expose that key in browser code."],
  ["Requests", "Use JSON request bodies and read JSON responses from the versioned api.musiccloud.io base URL."],
  ["Errors", "Every backend error includes a stable code, safe message, and errorId for support correlation."],
  ["Limits", "Validated clients are limited by their configured minute and day quotas."],
  ["Versioning", `This page is generated from public API version ${reference.version}.`],
] as const;
---

<div class="api-reference-shell">
  <div class="card-content-inset mb-8" data-api-reference-intro>
    <h1 class="text-hero font-medium tracking-tight leading-none mb-3">API reference</h1>
    <p class="text-lead text-fg-muted">Generated from the public OpenAPI contract for version {reference.version}.</p>
  </div>

  <div class="api-reference-layout">
    <ApiReferenceNav reference={reference} />

    <ApiContent data-api-search-root>
      <ApiContent.Chapter aria-labelledby="integration-guide">
        <ApiContent.Chapter.Header
          id="integration-guide"
          className="api-content__chapter-header--first"
          data-api-content-heading
        >
          <ApiContent.Chapter.Header.Icon>
            <IntegrationIcon aria-hidden="true" />
          </ApiContent.Chapter.Header.Icon>
          <ApiContent.Chapter.Header.Title>Integration guide</ApiContent.Chapter.Header.Title>
        </ApiContent.Chapter.Header>
        <ApiContent.Chapter.Body>
          <ContentCard>
            <ContentCard.Header>
              <ContentCard.Header.Title>Integration essentials</ContentCard.Header.Title>
            </ContentCard.Header>
            <ContentCard.Body>
              <ContentCard.Body.Stack>
                <div class="integration-panel-grid">
                  {
                    integrationItems.map(([title, body]) => {
                      const targetId = `integration-${title.replace(/[^a-zA-Z0-9]+/g, "-").toLowerCase()}`;
                      return (
                        <ContentPanel
                          id={targetId}
                          tabIndex={-1}
                          className="integration-panel"
                          data-api-search-entry
                          data-api-search-group="Integration guide"
                          data-api-search-title={title}
                          data-api-search-addon="Guide"
                          data-api-search-kind="chapter"
                        >
                          <ContentPanel.Header>
                            <ContentPanel.Header.Title>{title}</ContentPanel.Header.Title>
                          </ContentPanel.Header>
                          <ContentPanel.Content>
                            <p class="text-body text-fg-muted">{body}</p>
                          </ContentPanel.Content>
                        </ContentPanel>
                      );
                    })
                  }
                </div>
                <CodeBlock
                  label="Authenticated request"
                  language="bash"
                  code={`curl https://api.musiccloud.io/api/v1/resolve \\
  -H "X-API-Key: mc_live_<prefix>_<secret>" \\
  -H "Content-Type: application/json"`}
                />
              </ContentCard.Body.Stack>
            </ContentCard.Body>
          </ContentCard>
        </ApiContent.Chapter.Body>
      </ApiContent.Chapter>

      <ApiContent.Chapter aria-labelledby="sdk-downloads">
        <ApiContent.Chapter.Header id="sdk-downloads" data-api-content-heading>
          <ApiContent.Chapter.Header.Icon>
            <SdkIcon aria-hidden="true" />
          </ApiContent.Chapter.Header.Icon>
          <ApiContent.Chapter.Header.Title>SDK downloads</ApiContent.Chapter.Header.Title>
        </ApiContent.Chapter.Header>
        <ApiContent.Chapter.Body>
          <SdkSegmentedCard
            assets={catalog.assets}
            apiVersion={catalog.apiVersion}
            generatorVersion={catalog.generatorVersion}
          />
        </ApiContent.Chapter.Body>
      </ApiContent.Chapter>

      {
        reference.groups.map((group) => {
          const SectionIcon = iconForApiReferenceSection(group.name);
          const sectionLabel = apiReferenceSectionLabel(group.name);
          const headingId = `group-${group.name.replace(/[^a-zA-Z0-9]+/g, "-").toLowerCase()}`;
          return (
            <ApiContent.Chapter aria-labelledby={headingId}>
              <ApiContent.Chapter.Header id={headingId} data-api-content-heading>
                <ApiContent.Chapter.Header.Icon>
                  <SectionIcon aria-hidden="true" />
                </ApiContent.Chapter.Header.Icon>
                <ApiContent.Chapter.Header.Title>{sectionLabel}</ApiContent.Chapter.Header.Title>
              </ApiContent.Chapter.Header>
              <ApiContent.Chapter.Body>
                {group.operations.map((operation) => (
                  <EndpointOperation operation={operation} searchGroup={sectionLabel} />
                ))}
              </ApiContent.Chapter.Body>
            </ApiContent.Chapter>
          );
        })
      }

      <ApiContent.Chapter id="schemas" aria-labelledby="schemas-heading">
        <ApiContent.Chapter.Header id="schemas-heading" data-api-content-heading>
          <ApiContent.Chapter.Header.Icon>
            <SchemasIcon aria-hidden="true" />
          </ApiContent.Chapter.Header.Icon>
          <ApiContent.Chapter.Header.Title>Schemas</ApiContent.Chapter.Header.Title>
          <ApiContent.Chapter.Header.Addon>
            <button
              type="button"
              class="api-content__chapter-toggle"
              aria-label="Expand all schema cards"
              title="Expand all schema cards"
              data-schema-card-toggle-all
              data-schema-cards-all-expanded="false"
            >
              <ArrowCircleDownIcon className="api-content__chapter-toggle-down" aria-hidden="true" />
              <ArrowCircleUpIcon className="api-content__chapter-toggle-up" aria-hidden="true" />
            </button>
          </ApiContent.Chapter.Header.Addon>
        </ApiContent.Chapter.Header>
        <ApiContent.Chapter.Body>
          {Object.values(reference.schemas).map((schema) => <SchemaSection schema={schema} />)}
        </ApiContent.Chapter.Body>
      </ApiContent.Chapter>
    </ApiContent>
  </div>
  <SchemaCardsController />
  <ApiDocumentSearch client:load />
  <ScrollToTopButton />
</div>
