---
/**
 * Generated API reference content.
 *
 * This component is intentionally layout-only: `buildApiReference` and
 * `parseSdkCatalog` do all validation before data reaches here. Keeping this
 * focused makes the page testable with Astro's container API and lets the
 * route supply generated build inputs in production.
 */
import ApiReferenceNav from "@/components/docs/ApiReferenceNav.astro";
import { ApiDocumentSearch } from "@/components/docs/ApiDocumentSearch";
import CodeBlock from "@/components/docs/CodeBlock.astro";
import EndpointOperation from "@/components/docs/EndpointOperation.astro";
import SdkDownloadCard from "@/components/docs/SdkDownloadCard.astro";
import SchemaSection from "@/components/docs/SchemaSection.astro";
import ScrollToTopButton from "@/components/docs/ScrollToTopButton.astro";
import {
  apiReferenceSectionLabel,
  apiReferenceStaticSectionIcons,
  iconForApiReferenceSection,
} from "@/lib/api-reference-section-icons";
import { ContentCard } from "@/components/docs/ContentCard";
import type { ApiReference } from "@/lib/openapi-reference";
import type { SdkCatalog } from "@/lib/sdk-catalog";

interface Props {
  reference: ApiReference;
  catalog: SdkCatalog;
}

const { reference, catalog } = Astro.props;
const IntegrationIcon = apiReferenceStaticSectionIcons.integration;
const SdkIcon = apiReferenceStaticSectionIcons.sdk;
const SchemasIcon = apiReferenceStaticSectionIcons.schemas;

const integrationItems = [
  ["Authentication", "Send X-API-Key with your mc_live key. Never expose that key in browser code."],
  ["Requests", "Use JSON request bodies and read JSON responses from the versioned api.musiccloud.io base URL."],
  ["Errors", "Every backend error includes a stable code, safe message, and errorId for support correlation."],
  ["Limits", "Validated clients are limited by their configured minute and day quotas."],
  ["Versioning", `This page is generated from public API version ${reference.version}.`],
] as const;
---

<div class="api-reference-shell">
  <div class="mb-8" data-api-reference-intro>
    <h1 class="text-hero font-medium tracking-tight leading-none mb-3">API reference</h1>
    <p class="text-lead text-fg-muted">Generated from the public OpenAPI contract for version {reference.version}.</p>
  </div>

  <div class="api-reference-layout">
    <ApiReferenceNav reference={reference} />

    <div class="api-reference-content" data-api-search-root>
      <section aria-labelledby="integration-guide">
        <h2
          id="integration-guide"
          class="api-reference-content-heading api-reference-content-heading--first text-section font-medium tracking-tight scroll-mt-8"
          data-api-content-heading
        >
          <IntegrationIcon aria-hidden="true" />
          <span>Integration guide</span>
        </h2>
        <ContentCard className="mb-6">
          <ContentCard.Header>
            <ContentCard.Title>Integration essentials</ContentCard.Title>
          </ContentCard.Header>
          <ContentCard.Body>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mb-5">
              {
                integrationItems.map(([title, body]) => {
                  const targetId = `integration-${title.replace(/[^a-zA-Z0-9]+/g, "-").toLowerCase()}`;
                  return (
                  <article
                    id={targetId}
                    tabindex="-1"
                    class="rounded-button border border-border px-4 py-3"
                    data-api-search-entry
                    data-api-search-group="Integration guide"
                    data-api-search-title={title}
                    data-api-search-addon="Guide"
                    data-api-search-kind="chapter"
                  >
                    <h3 class="text-body font-medium text-fg mb-1">{title}</h3>
                    <p class="text-body text-fg-muted">{body}</p>
                  </article>
                  );
                })
              }
            </div>
            <CodeBlock
              label="Authenticated request"
              language="bash"
              code={`curl https://api.musiccloud.io/api/v1/resolve \\
  -H "X-API-Key: mc_live_<prefix>_<secret>" \\
  -H "Content-Type: application/json"`}
            />
          </ContentCard.Body>
        </ContentCard>
      </section>

      <section class="mb-6" id="sdk-downloads">
        <h2 class="api-reference-content-heading text-section font-medium tracking-tight mt-8 mb-5" data-api-content-heading>
          <SdkIcon aria-hidden="true" />
          <span>SDK downloads</span>
        </h2>
        <div class="grid grid-cols-1">
          {
            catalog.assets.map((asset) => (
              <SdkDownloadCard asset={asset} apiVersion={catalog.apiVersion} generatorVersion={catalog.generatorVersion} />
            ))
          }
        </div>
      </section>

      {
        reference.groups.map((group) => {
          const SectionIcon = iconForApiReferenceSection(group.name);
          const sectionLabel = apiReferenceSectionLabel(group.name);
          const headingId = `group-${group.name.replace(/[^a-zA-Z0-9]+/g, "-").toLowerCase()}`;
          return (
            <section aria-labelledby={headingId}>
              <h2
                id={headingId}
                class="api-reference-content-heading text-section font-medium tracking-tight mt-8 mb-5"
                data-api-content-heading
              >
                <SectionIcon aria-hidden="true" />
                <span>{sectionLabel}</span>
              </h2>
              {group.operations.map((operation) => <EndpointOperation operation={operation} searchGroup={sectionLabel} />)}
            </section>
          );
        })
      }

      <section id="schemas" aria-labelledby="schemas-heading">
        <h2
          id="schemas-heading"
          class="api-reference-content-heading text-section font-medium tracking-tight mt-8 mb-5"
          data-api-content-heading
        >
          <SchemasIcon aria-hidden="true" />
          <span>Schemas</span>
        </h2>
        {Object.values(reference.schemas).map((schema) => <SchemaSection schema={schema} />)}
      </section>
    </div>
  </div>
  <ApiDocumentSearch client:load />
  <ScrollToTopButton />
</div>
