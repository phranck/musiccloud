---
/** Renders one reachable OpenAPI schema through normalized entry/card compounds. */
import { ApiContent } from "@/components/docs/ApiContent";
import CodeBlock from "@/components/docs/CodeBlock.astro";
import { ContentCard } from "@/components/docs/ContentCard";
import OpenApiMarkdown from "@/components/docs/OpenApiMarkdown.astro";
import type { ApiSchema } from "@/lib/openapi-reference";

interface Props {
  schema: ApiSchema;
}

const { schema } = Astro.props;
---

<ApiContent.Entry
  data-api-search-entry
  data-api-search-group="Schemas"
  data-api-search-title={schema.name}
  data-api-search-addon="Schema"
  data-api-search-kind="schema"
  data-api-search-target={schema.anchor}
>
  <ApiContent.Entry.Title id={schema.anchor}>{schema.name}</ApiContent.Entry.Title>
  <ApiContent.Entry.Content>
    <ContentCard aria-labelledby={schema.anchor}>
      <ContentCard.Header>
        <ContentCard.Header.Title>JSON schema</ContentCard.Header.Title>
      </ContentCard.Header>
      <ContentCard.Body>
        <ContentCard.Body.Stack>
          {schema.description && <OpenApiMarkdown content={schema.description} className="text-body text-fg-muted" />}
          <CodeBlock language="json" code={JSON.stringify(schema.schema, null, 2)} />
        </ContentCard.Body.Stack>
      </ContentCard.Body>
      <ContentCard.Footer>
        <span class="font-mono text-code text-fg-muted">{schema.name}</span>
      </ContentCard.Footer>
    </ContentCard>
  </ApiContent.Entry.Content>
</ApiContent.Entry>
