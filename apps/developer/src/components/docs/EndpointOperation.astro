---
/**
 * One generated OpenAPI operation composed from the normalized API content,
 * endpoint card, nested section, and content-panel compounds.
 *
 * All examples and schemas remain escaped through `CodeBlock`; OpenAPI prose
 * is rendered only by the centralized safe Markdown component.
 */
import { ApiContent } from "@/components/docs/ApiContent";
import { AuthenticationCard } from "@/components/docs/AuthenticationCard";
import CodeBlock from "@/components/docs/CodeBlock.astro";
import { EndpointCard } from "@/components/docs/EndpointCard";
import OpenApiMarkdown from "@/components/docs/OpenApiMarkdown.astro";
import { ParameterCard } from "@/components/docs/ParameterCard";
import { RequestBodyCard } from "@/components/docs/RequestBodyCard";
import { ResponseCard } from "@/components/docs/ResponseCard";
import { ResponseTone, type ResponseToneValue } from "@/components/docs/responseCard.types";
import { apiReferenceOperationAnchor } from "@/lib/api-reference-anchor";
import { CodeIcon, KeyIcon, Send2Icon, TickCircleIcon } from "@/lib/icons";
import type { ApiOperation } from "@/lib/openapi-reference";

interface Props {
  operation: ApiOperation;
  searchGroup: string;
}

const { operation, searchGroup } = Astro.props;
const anchor = apiReferenceOperationAnchor(operation.method, operation.path);
const hasRequestBody = Boolean(operation.requestBody?.mediaTypes.length);

const responseTone = (status: string): ResponseToneValue => {
  if (status.startsWith("2")) return ResponseTone.Success;
  if (status.startsWith("4")) return ResponseTone.ClientError;
  if (status.startsWith("5")) return ResponseTone.ServerError;
  return ResponseTone.Neutral;
};

const responseLabel = (status: string) => {
  if (status.startsWith("2")) return "Success response";
  if (status.startsWith("4")) return "Client error response";
  if (status.startsWith("5")) return "Server error response";
  return "Response";
};
---

<ApiContent.Entry
  data-api-search-entry
  data-api-search-group={searchGroup}
  data-api-search-title={operation.navTitle}
  data-api-search-addon={`${operation.method} ${operation.path}`}
  data-api-search-kind="operation"
  data-api-search-target={anchor}
>
  <ApiContent.Entry.Title id={anchor} data-api-operation-title>
    {operation.navTitle}
  </ApiContent.Entry.Title>
  <ApiContent.Entry.Content>
    <EndpointCard aria-labelledby={anchor}>
      <EndpointCard.Header method={operation.method} data-api-search-ignore>
        <EndpointCard.Header.Request>
          <EndpointCard.Header.Request.Method>{operation.method}</EndpointCard.Header.Request.Method>
          <EndpointCard.Header.Request.Path>{operation.path}</EndpointCard.Header.Request.Path>
        </EndpointCard.Header.Request>
        <EndpointCard.Header.Addon>
          <EndpointCard.Header.Addon.Access>
            {operation.requiresApiKey ? "API key required" : "Public endpoint"}
          </EndpointCard.Header.Addon.Access>
        </EndpointCard.Header.Addon>
      </EndpointCard.Header>
      <EndpointCard.Body>
        {
          (operation.summary || operation.description) && (
            <EndpointCard.Body.Intro>
              {operation.summary && <p class="text-body text-fg">{operation.summary}</p>}
              {operation.description && (
                <OpenApiMarkdown content={operation.description} className="text-body text-fg-muted" />
              )}
            </EndpointCard.Body.Intro>
          )
        }

        <EndpointCard.Body.Stack>
          {
            operation.requiresApiKey && (
              <AuthenticationCard aria-labelledby={`${anchor}-authentication`}>
                <AuthenticationCard.Status>
                  <AuthenticationCard.Status.Icon>
                    <KeyIcon aria-hidden="true" />
                  </AuthenticationCard.Status.Icon>
                  <AuthenticationCard.Status.Title id={`${anchor}-authentication`}>
                    Authentication
                  </AuthenticationCard.Status.Title>
                </AuthenticationCard.Status>
                <AuthenticationCard.Content>
                  <p class="text-body text-fg-muted">
                    Send <code class="font-mono text-code text-code-fg">X-API-Key</code> with a valid
                    <code class="font-mono text-code text-code-fg">mc_live_…</code> key.
                  </p>
                </AuthenticationCard.Content>
              </AuthenticationCard>
            )
          }

          {
            operation.parameters.length > 0 && (
              <EndpointCard.Body.Section aria-labelledby={`${anchor}-parameters`}>
                <EndpointCard.Body.Section.Header>
                  <EndpointCard.Body.Section.Header.Icon>
                    <CodeIcon aria-hidden="true" />
                  </EndpointCard.Body.Section.Header.Icon>
                  <EndpointCard.Body.Section.Header.Title id={`${anchor}-parameters`}>
                    Parameters
                  </EndpointCard.Body.Section.Header.Title>
                </EndpointCard.Body.Section.Header>
                <EndpointCard.Body.Section.Body>
                  <dl class="content-panel-list">
                    {operation.parameters.map((parameter) => (
                      <ParameterCard>
                        <ParameterCard.Header>
                          <ParameterCard.Header.Name>{parameter.name}</ParameterCard.Header.Name>
                          <ParameterCard.Header.Location>{parameter.location}</ParameterCard.Header.Location>
                          {parameter.required && (
                            <ParameterCard.Header.Requirement>Required</ParameterCard.Header.Requirement>
                          )}
                        </ParameterCard.Header>
                        {parameter.description && (
                          <ParameterCard.Body>
                            <OpenApiMarkdown content={parameter.description} className="text-body text-fg-muted" />
                          </ParameterCard.Body>
                        )}
                      </ParameterCard>
                    ))}
                  </dl>
                </EndpointCard.Body.Section.Body>
              </EndpointCard.Body.Section>
            )
          }

          {
            hasRequestBody && (
              <EndpointCard.Body.Section aria-labelledby={`${anchor}-request-body`}>
                <EndpointCard.Body.Section.Header>
                  <EndpointCard.Body.Section.Header.Icon>
                    <Send2Icon aria-hidden="true" />
                  </EndpointCard.Body.Section.Header.Icon>
                  <EndpointCard.Body.Section.Header.Title id={`${anchor}-request-body`}>
                    Request body
                  </EndpointCard.Body.Section.Header.Title>
                </EndpointCard.Body.Section.Header>
                <EndpointCard.Body.Section.Body>
                  <div class="content-panel-list">
                    {operation.requestBody?.mediaTypes.map((media) => (
                      <RequestBodyCard>
                        <RequestBodyCard.Header>
                          <RequestBodyCard.Header.MediaType>{media.mediaType}</RequestBodyCard.Header.MediaType>
                          {media.schemaRef && (
                            <RequestBodyCard.Header.SchemaLink href={`#schema-${media.schemaRef}`}>
                              {media.schemaRef}
                            </RequestBodyCard.Header.SchemaLink>
                          )}
                        </RequestBodyCard.Header>
                        {media.example !== undefined && (
                          <RequestBodyCard.Body>
                            <RequestBodyCard.Body.Example>
                              <CodeBlock
                                label="Example"
                                language="json"
                                code={JSON.stringify(media.example, null, 2)}
                              />
                            </RequestBodyCard.Body.Example>
                          </RequestBodyCard.Body>
                        )}
                      </RequestBodyCard>
                    ))}
                  </div>
                </EndpointCard.Body.Section.Body>
              </EndpointCard.Body.Section>
            )
          }

          <EndpointCard.Body.Section aria-labelledby={`${anchor}-responses`}>
            <EndpointCard.Body.Section.Header>
              <EndpointCard.Body.Section.Header.Icon>
                <TickCircleIcon aria-hidden="true" />
              </EndpointCard.Body.Section.Header.Icon>
              <EndpointCard.Body.Section.Header.Title id={`${anchor}-responses`}>
                Responses
              </EndpointCard.Body.Section.Header.Title>
            </EndpointCard.Body.Section.Header>
            <EndpointCard.Body.Section.Body>
              <div class="content-panel-list">
                {
                  operation.responses.map((response) => {
                    const tone = responseTone(response.status);
                    return (
                      <ResponseCard tone={tone} aria-label={responseLabel(response.status)}>
                        <ResponseCard.Status status={response.status} tone={tone} />
                        <ResponseCard.Content>
                          <ResponseCard.Content.Summary>
                            <OpenApiMarkdown content={response.description} className="text-body text-fg-muted" />
                          </ResponseCard.Content.Summary>
                          {response.mediaTypes.length > 0 && (
                            <ResponseCard.Content.Meta>
                              {response.mediaTypes.map((media) => (
                                <div class="response-card__meta-row">
                                  <ResponseCard.Content.Meta.MediaType>
                                    {media.mediaType}
                                  </ResponseCard.Content.Meta.MediaType>
                                  {media.schemaRef && (
                                    <ResponseCard.Content.Meta.SchemaLink href={`#schema-${media.schemaRef}`}>
                                      {media.schemaRef}
                                    </ResponseCard.Content.Meta.SchemaLink>
                                  )}
                                </div>
                              ))}
                            </ResponseCard.Content.Meta>
                          )}
                        </ResponseCard.Content>
                      </ResponseCard>
                    );
                  })
                }
              </div>
            </EndpointCard.Body.Section.Body>
          </EndpointCard.Body.Section>
        </EndpointCard.Body.Stack>
      </EndpointCard.Body>
    </EndpointCard>
  </ApiContent.Entry.Content>
</ApiContent.Entry>
