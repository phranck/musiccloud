---
/**
 * Highlighted code block used by the API reference components.
 *
 * Shiki escapes the supplied source while adding token spans. The surrounding
 * copy control reads the rendered text back from the code node, so no raw source
 * is stored in inline JavaScript.
 */
import { createHash } from "node:crypto";
import { codeToHtml } from "shiki";
import { ContentPanel } from "@/components/docs/ContentPanel";
import { CopyIcon, CopySuccessIcon } from "@/lib/icons";

interface Props {
  code: string;
  label?: string;
  language?: "bash" | "json" | "typescript" | "python" | "swift";
  /** Allows a parent compound to reserve the remaining viewport height for the scrollable code frame. */
  fillAvailableHeight?: boolean;
  /** Avoids syntax-token DOM when an already formatted document is too large to render safely. */
  syntaxHighlight?: boolean;
  /** Holds build-time highlighted markup inert until a dialog controller inserts it. */
  deferredSourceId?: string;
}

const {
  code,
  label,
  language = "bash",
  fillAvailableHeight = false,
  syntaxHighlight = true,
  deferredSourceId,
} = Astro.props;
const blockId = `code-${createHash("sha256").update(`${label ?? ""}\n${language}\n${code}`).digest("hex").slice(0, 12)}`;
const lineCount = code.split(/\r?\n/).length;
const hasLineNumbers = syntaxHighlight && language !== "bash";
const hasVerticalOverflow = lineCount > 20;
const highlighted = syntaxHighlight
  ? await codeToHtml(code, {
      lang: language,
      theme: "github-dark-dimmed",
    })
  : null;
const deferredHighlightedSource =
  deferredSourceId && highlighted ? JSON.stringify(highlighted).replace(/</g, "\\u003c") : undefined;
---

<div
  class="code-block"
  data-code-block
  data-code-fill-available={fillAvailableHeight || undefined}
  data-code-deferred-source={deferredSourceId}
>
  {label && <p class="code-block__label text-code mb-2">{label}</p>}
  <div
    class="code-block__surface"
    data-code-line-numbers={hasLineNumbers || undefined}
    data-code-vertical-scroll={hasVerticalOverflow || undefined}
  >
    <div class="code-block__actions" data-api-search-ignore>
      <button
        type="button"
        class="code-block__copy text-fg-muted"
        aria-label="Copy code"
        title="Copy code"
        data-copy-code
        data-copy-target={blockId}
      >
        <CopyIcon className="code-block__copy-icon" data-copy-icon aria-hidden="true" />
        <span class="code-block__copy-success" data-copy-success hidden aria-hidden="true">
          <CopySuccessIcon className="code-block__copy-success-icon" aria-hidden="true" />
        </span>
      </button>
    </div>
    <span class="sr-only" aria-live="polite" data-copy-status></span>
    <ContentPanel id={blockId} className="code-block__frame">
      {
        deferredSourceId ? null : highlighted ? (
          <Fragment set:html={highlighted} />
        ) : (
          <pre class="shiki" tabindex="0"><code>{code}</code></pre>
        )
      }
    </ContentPanel>
    {
      deferredHighlightedSource && (
        <script id={deferredSourceId} type="application/json" is:inline set:html={deferredHighlightedSource}></script>
      )
    }
  </div>
</div>

<script>
  import { bindCodeCopyControls } from "@/lib/code-copy";

  bindCodeCopyControls(document);
</script>
