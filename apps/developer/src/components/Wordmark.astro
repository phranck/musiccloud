---
/**
 * Wordmark is the "musiccloud / developers" home link shared by the public
 * header (`PublicHeader.astro`), the dashboard shell
 * (`DashboardLayout.astro`) and the auth card (`AuthCard.astro`), so the
 * brand mark exists in exactly one place.
 *
 * The brand name renders in the musiccloud rainbow: one continuous gradient
 * masked onto the text (`.text-logo-rainbow` in global.css, stop-for-stop the
 * main site's banner colours), deliberately without an icon in front and
 * semibold. The "/ developer" suffix shares the same size (`--text-wordmark`)
 * but stays regular weight in muted foreground, slash included. The two
 * spans align on their baselines.
 */
interface Props {
  /** Extra classes merged onto the link, e.g. `justify-center mb-8` for the centred auth-card variant. */
  class?: string;
}

const { class: className } = Astro.props;
---

<a href="/" class:list={["flex items-baseline gap-2", className]}>
  <span class="text-logo-rainbow text-wordmark font-semibold">musiccloud</span>
  <span class="text-wordmark font-normal text-fg-muted">/ developer</span>
</a>
