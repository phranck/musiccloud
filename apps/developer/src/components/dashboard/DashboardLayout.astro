---
/**
 * DashboardLayout is the signed-in shell for the developer portal: a top header
 * (wordmark + the shared avatar menu, mirroring the public `PublicHeader` for
 * consistency) over a two-column body (sidebar nav + panel slot). Wraps
 * `BaseLayout` so a dashboard page only supplies its panel content plus the
 * active tab; the chrome lives here once (DRY across future dashboard tabs).
 *
 * All geometry is token-driven (`--radius-card`, `--radius-button`, hairline
 * `--color-border`, glassy `--color-surface`) per the project geometry rules;
 * no ad-hoc radii or colours. The sidebar entries come from `DASHBOARD_NAV`, the
 * single source of truth for labels, links and the "coming soon" placeholders.
 */
import { AvatarMenu } from "@/components/portal/AvatarMenu";
import DashboardNavigation from "@/components/dashboard/DashboardNavigation.astro";
import Wordmark from "@/components/Wordmark.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import type { DashboardTabValue } from "@/lib/dashboardTabs";
import type { Account } from "@/lib/session";

interface Props {
  /** The authenticated account whose identity is shown in the header. */
  account: Account;
  /** The currently active sidebar tab, highlighted in the nav. */
  active: DashboardTabValue;
  /** Document `<title>`, forwarded to {@link BaseLayout}. */
  title?: string;
}

const { account, active, title } = Astro.props;
---

<BaseLayout title={title}>
<header class="dashboard-header">
  <div class="dashboard-header__inner developer-shell">
    <Wordmark />

    <AvatarMenu
      client:load
      account={{ email: account.email, displayName: account.displayName, avatarUrl: account.avatarUrl }}
      showDashboard={false}
    />
  </div>
</header>

<div class="dashboard-shell developer-shell">
  <DashboardNavigation active={active} />

  <main class="dashboard-content">
    <slot />
  </main>
</div>
</BaseLayout>
