---
/**
 * Static ambient background.
 *
 * Deliberately no JavaScript and no runtime animation: the soft radial fields
 * are painted once and then stay fixed so the share/player UI can keep the
 * main thread and compositor budget for interactive controls.
 */
---

<div class="fixed inset-0 -z-10 overflow-hidden bg-background" aria-hidden="true">
  <div
    class="absolute inset-0"
    style="background:
      radial-gradient(circle at 8% 10%, rgba(40, 168, 216, 0.22) 0, rgba(40, 168, 216, 0.12) 18%, transparent 42%),
      radial-gradient(circle at 92% 36%, rgba(212, 168, 67, 0.14) 0, rgba(212, 168, 67, 0.08) 20%, transparent 44%),
      radial-gradient(circle at 45% 105%, rgba(22, 140, 180, 0.18) 0, rgba(22, 140, 180, 0.09) 22%, transparent 48%);"
  ></div>
</div>
