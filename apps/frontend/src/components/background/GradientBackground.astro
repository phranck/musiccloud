---
/**
 * Ambient app background (plan MC-029 Phase 4).
 *
 * Two layers:
 * 1. The three static radial gradients — the instant, zero-JS paint that
 *    keeps LCP untouched and serves bots/no-WebGL visitors unchanged.
 * 2. The night-sky WebGL island (worker-rendered): real northern stars
 *    rotating around Polaris behind drifting procedural clouds. Its canvas
 *    starts transparent and fades in over the gradients once the first
 *    frame is ready, so there is never a black or half-initialised flash.
 *
 * The previous box-shadow starfield with its 300 s full-viewport spin — a
 * documented paint-load source — is gone; stars render on the GPU now.
 * (The dashboard auth background keeps its own CSS starfield; only the
 * public frontend migrated.)
 */
import { BackgroundScene } from "@/components/background/BackgroundScene";
---

<div class="fixed inset-0 -z-10 overflow-hidden bg-background" aria-hidden="true">
  <div
    class="absolute inset-0"
    style="background:
      radial-gradient(circle at 8% 10%, rgba(40, 168, 216, 0.22) 0, rgba(40, 168, 216, 0.12) 18%, transparent 42%),
      radial-gradient(circle at 92% 36%, rgba(212, 168, 67, 0.14) 0, rgba(212, 168, 67, 0.08) 20%, transparent 44%),
      radial-gradient(circle at 45% 105%, rgba(22, 140, 180, 0.18) 0, rgba(22, 140, 180, 0.09) 22%, transparent 48%);"
  ></div>
  <BackgroundScene client:idle />
</div>
