---
/**
 * Static centered musiccloud logo linking home, for SSR / no-JS share-page
 * fallbacks (bot markup and the deferred-content shell in `[shortId].astro`).
 *
 * The React sibling `ShareLogoHeader.tsx` carries an `onLogoClick` handler for
 * in-page transitions; this Astro version intentionally has none — it must
 * render and work without hydration, so the anchor is a plain `href="/"` link.
 * `LogoView` SSRs to a static `<img>` here (no `client:*` directive).
 */
import { LogoView } from "@/components/ui/LogoView";
---

<div class="mb-4 text-center sm:mb-6">
  <a href="/" aria-label="Go to musiccloud home" class="inline-block">
    <LogoView className="w-56 sm:w-64 h-auto" />
  </a>
</div>
