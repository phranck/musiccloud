---
/**
 * Static share-result placeholder for Astro-rendered shells.
 * Mirrors the client-side ShareResultPlaceholder used on the landing page,
 * but stays CSS-only so direct share pages can reserve the result area before
 * DeferredShareContent streams in. It is intentionally invisible: its job is
 * layout stability, not visual skeleton UI.
 */
interface Props {
  className?: string;
}

const { className = "" } = Astro.props;
---

<div
  class:list={["mx-auto w-full max-w-[512px] min-[1080px]:max-w-[1048px] opacity-0 pointer-events-none", className]}
  aria-hidden="true"
>
  <div class="hidden min-[1080px]:grid grid-cols-[512px_512px] gap-6">
    <div class="h-[560px]"></div>
    <div class="h-[560px]"></div>
  </div>
  <div class="min-[1080px]:hidden h-[520px]"></div>
</div>
