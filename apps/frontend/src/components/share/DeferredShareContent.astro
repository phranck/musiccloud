---
/**
 * Server Island that fetches share/content-page data and renders the
 * main content region for the `/[shortId]` route (browser path only).
 *
 * Rendered with `server:defer` from `pages/[shortId].astro` so the shell
 * (background + fallback logo) flushes to the browser within a few
 * milliseconds. While this island runs on the server, the parent's
 * `slot="fallback"` is painted; when the island finishes, Astro swaps
 * the fallback out for the real `<main>`.
 *
 * Bots never hit this path — they are served by the synchronous SSR
 * branch in `[shortId].astro` so OG/Twitter meta can be in `<head>`.
 */

import { fetchPublicContentPage, fetchRandomExample, fetchShareData } from "@/api/client";
import { LandingPage } from "@/components/landing/LandingPage";
import { PageOverlayIsland } from "@/components/layout/PageOverlayIsland";
import { SegmentedPageFullscreen } from "@/components/layout/SegmentedPageFullscreen";
import { MarkdownHtml } from "@/components/markdown/MarkdownHtml";
import { RecessedCard } from "@/components/cards/RecessedCard";
import { CcSharePageShell } from "@/components/share/CcSharePageShell";
import { ShareErrorShell } from "@/components/share/ShareErrorShell";
import { SharePageShell } from "@/components/share/SharePageShell";
import { shareCopy } from "@/copy/share";
import { resolveShortRouteResults } from "@/lib/share/short-route-result";
import { buildCcSharePageProps, buildShareViewFromSharePageResponse, isCcSharePageResponse } from "@/lib/share/share-view";

interface Props {
  shortId: string;
}

const { shortId } = Astro.props;

const clientIp = Astro.clientAddress;
const [contentResult, shareResult] = await Promise.all([
  fetchPublicContentPage(shortId, clientIp),
  fetchShareData(shortId, clientIp, Astro.request.headers),
]);
const routeResult = resolveShortRouteResults(contentResult, shareResult);
const contentPage = routeResult.kind === "content" ? routeResult.data : null;
const data = routeResult.kind === "share" ? routeResult.data : null;
const notFound = routeResult.kind === "not-found";
const routeError = routeResult.kind === "error" ? routeResult.error : null;
const errorLabels = {
  back: shareCopy.error.back,
  code: shareCopy.error.code,
  copied: shareCopy.error.copied,
  copy: shareCopy.error.copy,
  description: shareCopy.error.description,
  reference: shareCopy.error.reference,
  title: shareCopy.error.title,
};

// Overlay-mode content pages render as "the landing page with an overlay open"
// (see the overlay branch below); fetch the hero's live-example just like the
// home route so the background matches the real landing page.
const overlayMode = !!contentPage && contentPage.displayMode !== "fullscreen";
const exampleShortId = overlayMode ? ((await fetchRandomExample())?.shortId ?? null) : null;

// CC entities render through their own shell (the commercial share-view builder
// handles only track/album/artist); split the two here.
const ccPageProps = data && isCcSharePageResponse(data) ? buildCcSharePageProps(data) : null;
const shareView = data && !isCcSharePageResponse(data) ? buildShareViewFromSharePageResponse(data, shortId) : null;
const shareConfig = shareView?.config ?? null;
const pageTitle = notFound
  ? null
  : contentPage
    ? `${contentPage.title} - musiccloud`
    : (ccPageProps?.pageTitle ?? shareView?.pageTitle ?? null);
const artworkUrl = contentPage ? null : (ccPageProps?.artworkUrl ?? shareView?.artworkUrl);
---

{notFound && <script is:inline>window.location.replace("/404");</script>}

{routeError && <ShareErrorShell client:load error={routeError} labels={errorLabels} />}

{!notFound && !routeError && pageTitle && (
  <script is:inline define:vars={{ pageTitle, artworkUrl: artworkUrl ?? null }}>
    document.title = pageTitle;
    if (artworkUrl) {
      var link = document.createElement("link");
      link.rel = "preload";
      link.as = "image";
      link.href = artworkUrl;
      document.head.appendChild(link);
    }
  </script>
)}

{!notFound && !routeError && contentPage && contentPage.displayMode === "fullscreen" && (
  <main id="main-content" class="flex-1 w-full max-w-3xl mx-auto px-4 sm:px-6 pt-content-safe pb-12 animate-slide-up">
    {contentPage.showTitle && contentPage.pageType !== "segmented" && (
      <h1
        class:list={[
          "text-3xl sm:text-4xl font-bold tracking-[-0.04em] mb-8",
          {
            "text-left": contentPage.titleAlignment === "left",
            "text-center": contentPage.titleAlignment === "center",
            "text-right": contentPage.titleAlignment === "right",
          },
        ]}
      >
        {contentPage.title}
      </h1>
    )}
    {contentPage.pageType === "segmented" ? (
      <SegmentedPageFullscreen client:load page={contentPage} />
    ) : contentPage.contentCardStyle === "recessed" ? (
      <RecessedCard client:load className="px-6 py-6">
        <MarkdownHtml html={contentPage.contentHtml} className="prose prose-invert max-w-none" />
      </RecessedCard>
    ) : (
      <MarkdownHtml client:load html={contentPage.contentHtml} className="prose prose-invert max-w-none" />
    )}
  </main>
)}

{!notFound && !routeError && overlayMode && (
  <Fragment>
    {/* An overlay-mode content page IS the landing page with an overlay open.
        Render the same shell as index.astro so a direct load / reload / shared
        link shows the homepage behind the centred overlay (not the share-page
        chrome). showFooter=false because the route's DeferredFooter already
        renders the footer. PageOverlayIsland is a sibling of <main> — never
        inside a transformed wrapper — so its position:fixed frame stays
        viewport-anchored and centred. */}
    <main id="main-content" class="flex-1 flex flex-col">
      <LandingPage client:idle showFooter={false} exampleShortId={exampleShortId} />
    </main>
    <PageOverlayIsland client:load initialPage={contentPage} />
  </Fragment>
)}

{!notFound && !routeError && !contentPage && ccPageProps && (
  <CcSharePageShell
    client:load
    config={ccPageProps.config}
    artistName={ccPageProps.artistName}
    artistInfo={ccPageProps.artistInfo}
    labels={ccPageProps.labels}
  />
)}

{!notFound && !routeError && !contentPage && shareView && shareConfig && (
  <SharePageShell
    client:load
    config={shareConfig}
    artistName={shareView.artistName}
    artistInfoContext={shareView.artistInfoContext}
  />
)}

{/* Always-on overlay host (see note in [shortId].astro); needed when the
    current page is fullscreen content or a share page so nav-click-opened
    overlays still work. Rendered here because it depends on knowing
    whether contentPage is overlay-mode (which already has its own). */}
{!notFound && !routeError && (!contentPage || contentPage.displayMode === "fullscreen") && (
  <PageOverlayIsland client:load initialPage={null} />
)}
