---
export const prerender = true;

import { ENDPOINTS } from "@musiccloud/shared";
import { LandingPage } from "@/components/LandingPage";
import GradientBackground from "@/components/background/GradientBackground.astro";
import SparklingStars from "@/components/background/SparklingStars.astro";
import { PageOverlayIsland } from "@/components/layout/PageOverlayIsland";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { loadNav } from "@/lib/loadNav";

const { header: headerNav, footer: footerNav } = await loadNav();
---

<BaseLayout
  title="musiccloud - Share music across every platform"
  description="Paste a Spotify, Apple Music, or YouTube link and get a universal share link that works everywhere."
  canonicalUrl="https://musiccloud.io"
>
  <Fragment slot="head">
    <meta name="title" content="musiccloud - Share music across every platform" />

    <!-- OpenGraph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content="musiccloud" />
    <meta property="og:description" content="Paste a Spotify, Apple Music, or YouTube link and get a universal share link that works everywhere." />
    <meta property="og:url" content="https://musiccloud.io" />
    <meta property="og:site_name" content="musiccloud" />
    <meta property="og:image" content="https://musiccloud.io/og/musiccloud.jpg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="musiccloud - Share music across every platform" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="musiccloud" />
    <meta name="twitter:description" content="Paste a Spotify, Apple Music, or YouTube link and get a universal share link that works everywhere." />
    <meta name="twitter:image" content="https://musiccloud.io/og/musiccloud.jpg" />

    <!-- JSON-LD: WebApplication -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "musiccloud",
      "description": "Share music across every platform",
      "url": "https://musiccloud.io",
      "image": "https://musiccloud.io/og/musiccloud.jpg",
      "applicationCategory": "MusicApplication",
      "operatingSystem": "Web",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
    })} />
  </Fragment>

  <!-- Redirect ?share=<streaming-url> to the share page via the backend. Runs before React hydration.
       The param name must not be "url" because Vite's dev server intercepts `/?url=...` as an
       asset-URL import query and returns 403 before Astro can handle the request. -->
  <script is:inline define:vars={{ redirectEndpoint: ENDPOINTS.frontend.redirect }}>
    (function () {
      var u = new URLSearchParams(location.search).get("share");
      if (u) location.replace(redirectEndpoint + "?url=" + encodeURIComponent(u));
    })();
  </script>

  <!-- Static ambient background: no JS, no hydration -->
  <GradientBackground />

  <div class="min-h-dvh flex flex-col">
    <LandingPage client:idle headerNav={headerNav} footerNav={footerNav} />
  </div>

  <!-- Mounted with null initialPage so nav clicks on overlay-mode pages
       open client-side (no full reload). OverlayProvider advertises its
       presence via window.__mcOverlayActive for PageHeader.handleNavClick. -->
  <PageOverlayIsland client:load initialPage={null} />

  <!-- Non-essential ambient UI: static (CSS-only animation) -->
  <SparklingStars />

  <!-- SSR fallback for no-JS -->
  <noscript>
    <main style="max-width: 640px; margin: 0 auto; padding: 4rem 1rem; text-align: center; font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', system-ui, sans-serif;">
      <h1 style="font-size: 1.5rem; font-weight: bold; color: #F5F5F7; margin-bottom: 0.5rem;">
        musiccloud
      </h1>
      <p style="font-size: 1.25rem; color: #F5F5F7; margin-bottom: 2rem;">
        Paste a link or search by name. Share it everywhere.
      </p>
      <p style="color: #86868B;">
        This app requires JavaScript to work. Please enable JavaScript in your browser.
      </p>
    </main>
  </noscript>
</BaseLayout>
