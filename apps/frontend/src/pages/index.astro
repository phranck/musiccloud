---
import { ErrorBoundary } from "@/components/ui/ErrorBoundary";
import { LandingPage } from "@/components/LandingPage";
/**
 * Landing Page - musiccloud
 *
 * Static page (prerendered). The LandingPage React component
 * handles all client-side interactivity as an Astro island.
 */
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="musiccloud - Share music across every platform"
  description="Paste a Spotify, Apple Music, or YouTube link and get a universal share link that works everywhere."
  canonicalUrl="https://musiccloud.io"
>
  <Fragment slot="head">
    <meta name="title" content="musiccloud - Share music across every platform" />

    <!-- OpenGraph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content="musiccloud" />
    <meta property="og:description" content="Paste a Spotify, Apple Music, or YouTube link and get a universal share link that works everywhere." />
    <meta property="og:url" content="https://musiccloud.io" />
    <meta property="og:site_name" content="musiccloud" />
    <meta property="og:image" content="https://musiccloud.io/og/musiccloud.jpg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="musiccloud - Share music across every platform" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="musiccloud" />
    <meta name="twitter:description" content="Paste a Spotify, Apple Music, or YouTube link and get a universal share link that works everywhere." />
    <meta name="twitter:image" content="https://musiccloud.io/og/musiccloud.jpg" />

    <!-- JSON-LD: WebApplication -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "musiccloud",
      "description": "Share music across every platform",
      "url": "https://musiccloud.io",
      "image": "https://musiccloud.io/og/musiccloud.jpg",
      "applicationCategory": "MusicApplication",
      "operatingSystem": "Web",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
    })} />
  </Fragment>

  <!-- Redirect ?url=<streaming-url> to the share page via the backend. Runs before React hydration. -->
  <script is:inline>
    (function () {
      var u = new URLSearchParams(location.search).get("url");
      if (u) location.replace("/api/v1/redirect?url=" + encodeURIComponent(u));
    })();
  </script>

  <div class="min-h-dvh flex flex-col">
    <ErrorBoundary client:load>
      <LandingPage client:load />
    </ErrorBoundary>
  </div>

  <!-- SSR fallback for no-JS -->
  <noscript>
    <main style="max-width: 640px; margin: 0 auto; padding: 4rem 1rem; text-align: center; font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', system-ui, sans-serif;">
      <h1 style="font-size: 1.5rem; font-weight: bold; color: #F5F5F7; margin-bottom: 0.5rem;">
        musiccloud
      </h1>
      <p style="font-size: 1.25rem; color: #F5F5F7; margin-bottom: 2rem;">
        Paste a link or search by name. Share it everywhere.
      </p>
      <p style="color: #86868B;">
        This app requires JavaScript to work. Please enable JavaScript in your browser.
      </p>
    </main>
  </noscript>
</BaseLayout>
