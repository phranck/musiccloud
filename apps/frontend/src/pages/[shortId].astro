---
/**
 * Share Page - SSR rendered
 *
 * Fetches share data from the backend API and renders the page
 * with OG meta tags for link preview bots.
 * Handles both track and album short IDs.
 */
export const prerender = false;

import type { ServiceId } from "@musiccloud/shared";
import { buildMetaLine, isValidServiceId } from "@musiccloud/shared";
import { fetchPublicContentPage, fetchShareData } from "@/api/client";
import GradientBackground from "@/components/background/GradientBackground.astro";
import DeferredFooter from "@/components/layout/DeferredFooter.astro";
import DeferredHeader from "@/components/layout/DeferredHeader.astro";
import { PageOverlayIsland } from "@/components/layout/PageOverlayIsland";
import { SegmentedPageFullscreen } from "@/components/layout/PageOverlayContent";
import { ShareLayout } from "@/components/share/ShareLayout";
import { LogoView } from "@/components/ui/LogoView";
import { getLocaleFromCookie } from "@/i18n/locales";
import { loadTranslations, makeT } from "@/i18n/server";
import BaseLayout from "@/layouts/BaseLayout.astro";
import type { ShareContentConfiguration } from "@/lib/types/media-card";

const { shortId } = Astro.params;

if (!shortId) {
  return Astro.redirect("/");
}

// SSR i18n: read locale from cookie, load translations
const locale = getLocaleFromCookie(Astro.cookies.get("mc:locale")?.value);
const translations = await loadTranslations(locale);
const t = makeT(translations);

// Both routes share the same `/:slug` URL space — content pages take
// precedence over share lookups. We fire both fetches in parallel (instead
// of awaiting the content-page decision first) so the total wait time is
// the max of the two, not the sum. The extra share fetch when a content
// page exists is cheap and avoids a visible cold start on regular share
// pages, which are the common case. Nav loads in separate Server Islands
// and therefore does not block this frontmatter at all.
const [contentPage, shareData] = await Promise.all([
  fetchPublicContentPage(shortId),
  fetchShareData(shortId),
]);
const data = contentPage ? null : shareData;

if (!contentPage && !data) {
  return Astro.redirect("/404", 302);
}

// Share-page derivations (only when share data is present, not a content page)
const isAlbum = data?.type === "album";
const isArtist = data?.type === "artist";
const og = data?.og ?? null;
const track = data?.track ?? null;
const album = data?.album ?? null;
const artist = data?.artist ?? null;

const artistDisplay = isArtist
  ? ""
  : isAlbum
    ? (album?.artists.join(", ") ?? "")
    : (track?.artists.join(", ") ?? "");

const artworkUrl = isArtist ? artist?.imageUrl : isAlbum ? album?.artworkUrl : track?.artworkUrl;
const displayTitle = isArtist ? (artist?.name ?? "") : isAlbum ? (album?.title ?? "") : (track?.title ?? "");

// Pre-compute meta lines using server-side translations
const trackMetaLine = track ? buildMetaLine({ durationMs: track.durationMs, releaseDate: track.releaseDate }) : null;
const albumYear = album?.releaseDate?.slice(0, 4);
const albumMetaLine = isAlbum
  ? [album?.totalTracks ? t("results.albumTracks", { count: String(album.totalTracks) }) : null, albumYear]
      .filter(Boolean)
      .join(" \u00B7 ")
  : null;
const artistMetaLine = isArtist ? artist?.genres?.join(", ") : null;

// Build platform links (filter invalid services) — empty when content page
const platformLinks = (data?.links ?? [])
  .filter((link) => isValidServiceId(link.service))
  .map((link) => ({
    platform: link.service as ServiceId,
    url: link.url,
  }));

const platformsLabelKey = isArtist
  ? "results.viewArtistOn"
  : isAlbum
    ? "results.openAlbumOn"
    : "results.listenOn";

const shareConfig: ShareContentConfiguration | null = data
  ? {
      type: "share",
      title: displayTitle,
      artist: artistDisplay,
      artworkUrl: artworkUrl ?? "",
      album: isAlbum ? undefined : (track?.albumName ?? undefined),
      isExplicit: !isAlbum && !isArtist && track?.isExplicit ? true : undefined,
      previewUrl: isArtist ? undefined : isAlbum ? (album?.previewUrl ?? undefined) : (track?.previewUrl ?? undefined),
      previewRefreshable: !isArtist && !isAlbum ? track?.previewRefreshable : undefined,
      shortId,
      metaLine: isArtist ? artistMetaLine || undefined : isAlbum ? albumMetaLine || undefined : trackMetaLine || undefined,
      platforms: platformLinks,
      platformsLabel: t(platformsLabelKey),
      platformsLabelKey,
      shortUrl: data.shortUrl,
    }
  : null;

const pageTitle = contentPage
  ? `${contentPage.title} - musiccloud`
  : isArtist
    ? `${displayTitle} - musiccloud`
    : `${displayTitle} by ${artistDisplay} - musiccloud`;
---

<BaseLayout
  title={pageTitle}
  canonicalUrl={contentPage ? `https://musiccloud.io/${contentPage.slug}` : og?.url}
  preloadImage={artworkUrl ?? undefined}
  lang={locale}
>
  {og && (
    <Fragment slot="head">
      <meta property="og:type" content={isArtist ? "profile" : isAlbum ? "music.album" : "music.song"} />
      <meta property="og:title" content={og.title} />
      <meta property="og:description" content={og.description} />
      {og.image && <meta property="og:image" content={og.image} />}
      <meta property="og:image:width" content="1200" />
      <meta property="og:image:height" content="630" />
      <meta property="og:image:alt" content={isArtist ? displayTitle : `${displayTitle} by ${artistDisplay}`} />
      <meta property="og:url" content={og.url} />
      <meta property="og:site_name" content="musiccloud" />

      <meta name="twitter:card" content="summary_large_image" />
      <meta name="twitter:title" content={og.title} />
      <meta name="twitter:description" content={og.description} />
      {og.image && <meta name="twitter:image" content={og.image} />}

      <link rel="dns-prefetch" href="//i.scdn.co" />
      <link rel="dns-prefetch" href="//is1-ssl.mzstatic.com" />
    </Fragment>
  )}

  <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-accent focus:text-white focus:rounded-lg">
    {t("a11y.skipToContent")}
  </a>

  <DeferredHeader server:defer />

  <GradientBackground />

  <div class="min-h-dvh flex flex-col">
    {contentPage && contentPage.displayMode === "fullscreen" && (
      <main id="main-content" class="flex-1 w-full max-w-3xl mx-auto px-4 sm:px-6 py-12">
        {contentPage.showTitle && contentPage.pageType !== "segmented" && (
          <h1
            class:list={[
              "text-3xl sm:text-4xl font-bold tracking-[-0.04em] mb-8",
              {
                "text-left": contentPage.titleAlignment === "left",
                "text-center": contentPage.titleAlignment === "center",
                "text-right": contentPage.titleAlignment === "right",
              },
            ]}
          >
            {contentPage.title}
          </h1>
        )}
        {contentPage.pageType === "segmented" ? (
          <SegmentedPageFullscreen client:load page={contentPage} />
        ) : (
          // set:html trust boundary: `contentPage.contentHtml` is rendered by the
          // backend markdown renderer from admin-authored source and arrives
          // sanitized. Do not feed this with any data that has not been through
          // the backend's renderer. See `PageOverlayContent.tsx:41` for the
          // companion boundary note.
          <article class="prose prose-invert max-w-none" set:html={contentPage.contentHtml} />
        )}
      </main>
    )}

    {contentPage && contentPage.displayMode !== "fullscreen" && (
      <main id="main-content" class="flex-1 flex flex-col items-center justify-center px-4 sm:px-6 py-12">
        <div class="text-center">
          <a href="/" aria-label="Go to musiccloud home" class="inline-block">
            <LogoView className="w-56 sm:w-64 h-auto" />
          </a>
        </div>
        <PageOverlayIsland client:load initialPage={contentPage} />
      </main>
    )}

    {!contentPage && (
      <main id="main-content" class="flex-1 flex flex-col items-center justify-center px-4 sm:px-6 py-12">
        <div class="mb-6 text-center">
          <a href="/" aria-label="Go to musiccloud home" class="inline-block">
            <LogoView className="w-56 sm:w-64 h-auto" />
          </a>
        </div>
        {shareConfig && (
          <ShareLayout client:load config={shareConfig} artistName={isArtist ? displayTitle : artistDisplay} initialLocale={locale} />
        )}
      </main>
    )}

    <DeferredFooter server:defer />
  </div>

  <!-- Always-on overlay host so nav clicks on overlay-mode pages open
       client-side without a full reload. When we already rendered an
       overlay above (inside the contentPage displayMode !== "fullscreen"
       branch), that island carries `initialPage`; this sibling with
       initialPage=null is a no-op because both share the same event +
       window-flag channel. When the current page is fullscreen or a
       share page, this island is the only OverlayProvider on the page
       and is responsible for opening future overlays on nav clicks. -->
  {(!contentPage || contentPage.displayMode === "fullscreen") && (
    <PageOverlayIsland client:load initialPage={null} />
  )}
</BaseLayout>
