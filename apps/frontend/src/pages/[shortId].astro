---
/**
 * Share Page - SSR rendered
 *
 * Fetches share data from the backend API and renders the page
 * with OG meta tags for link preview bots.
 * Handles both track and album short IDs.
 */
export const prerender = false;

import type { Platform } from "@musiccloud/shared";
import { buildMetaLine, isValidPlatform } from "@musiccloud/shared";
import { fetchShareData } from "@/api/client";
import { GradientBackground } from "@/components/background/GradientBackground";
import { AppFooterIsland } from "@/components/layout/AppFooterIsland";
import { PageHeaderIsland } from "@/components/layout/PageHeaderIsland";
import { ShareLayout } from "@/components/share/ShareLayout";
import { BrandName } from "@/components/ui/BrandName";
import { getLocaleFromCookie } from "@/i18n/locales";
import { loadTranslations, makeT } from "@/i18n/server";
import BaseLayout from "@/layouts/BaseLayout.astro";
import type { ShareContentConfiguration } from "@/lib/types/media-card";

const { shortId } = Astro.params;

if (!shortId) {
  return Astro.redirect("/");
}

// SSR i18n: read locale from cookie, load translations
const locale = getLocaleFromCookie(Astro.cookies.get("mc:locale")?.value);
const translations = await loadTranslations(locale);
const t = makeT(translations);

// Fetch share data from backend
const data = await fetchShareData(shortId);

if (!data) {
  return Astro.redirect("/", 302);
}

const isAlbum = data.type === "album";
const isArtist = data.type === "artist";
const og = data.og;
const track = data.track ?? null;
const album = data.album ?? null;
const artist = data.artist ?? null;

const artistDisplay = isArtist
  ? ""
  : isAlbum
    ? (album?.artists.join(", ") ?? "")
    : (track?.artists.join(", ") ?? "");

const artworkUrl = isArtist ? artist?.imageUrl : isAlbum ? album?.artworkUrl : track?.artworkUrl;
const displayTitle = isArtist ? (artist?.name ?? "") : isAlbum ? (album?.title ?? "") : (track?.title ?? "");

// Pre-compute meta lines using server-side translations
const trackMetaLine = track ? buildMetaLine({ durationMs: track.durationMs, releaseDate: track.releaseDate }) : null;
const albumYear = album?.releaseDate?.slice(0, 4);
const albumMetaLine = isAlbum
  ? [album?.totalTracks ? t("results.albumTracks", { count: String(album.totalTracks) }) : null, albumYear]
      .filter(Boolean)
      .join(" \u00B7 ")
  : null;
const artistMetaLine = isArtist ? artist?.genres?.join(", ") : null;

// Build platform links (filter invalid services)
const platformLinks = data.links
  .filter((link) => isValidPlatform(link.service))
  .map((link) => ({
    platform: link.service as Platform,
    url: link.url,
  }));

// Determine platforms label key
const platformsLabelKey = isArtist
  ? "results.viewArtistOn"
  : isAlbum
    ? "results.openAlbumOn"
    : "results.listenOn";

// Build the ShareContentConfiguration (fully JSON-serializable, passed to React island)
const shareConfig: ShareContentConfiguration = {
  type: "share",
  title: displayTitle,
  artist: artistDisplay,
  artworkUrl: artworkUrl ?? "",
  album: isAlbum ? undefined : (track?.albumName ?? undefined),
  isExplicit: !isAlbum && !isArtist && track?.isExplicit ? true : undefined,
  previewUrl: isArtist ? undefined : isAlbum ? (album?.previewUrl ?? undefined) : (track?.previewUrl ?? undefined),
  metaLine: isArtist ? artistMetaLine || undefined : isAlbum ? albumMetaLine || undefined : trackMetaLine || undefined,
  platforms: platformLinks,
  platformsLabel: t(platformsLabelKey),
  platformsLabelKey,
  shortUrl: data.shortUrl,
};

const pageTitle = isArtist
  ? `${displayTitle} - musiccloud`
  : `${displayTitle} by ${artistDisplay} - musiccloud`;
---

<BaseLayout
  title={pageTitle}
  canonicalUrl={og.url}
  preloadImage={artworkUrl ?? undefined}
  lang={locale}
>
  <Fragment slot="head">
    <!-- OpenGraph Tags (critical for link previews) -->
    <meta property="og:type" content={isArtist ? "profile" : isAlbum ? "music.album" : "music.song"} />
    <meta property="og:title" content={og.title} />
    <meta property="og:description" content={og.description} />
    {og.image && <meta property="og:image" content={og.image} />}
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={isArtist ? displayTitle : `${displayTitle} by ${artistDisplay}`} />
    <meta property="og:url" content={og.url} />
    <meta property="og:site_name" content="musiccloud" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={og.title} />
    <meta name="twitter:description" content={og.description} />
    {og.image && <meta name="twitter:image" content={og.image} />}

    <!-- DNS prefetch for artwork CDNs -->
    <link rel="dns-prefetch" href="//i.scdn.co" />
    <link rel="dns-prefetch" href="//is1-ssl.mzstatic.com" />
  </Fragment>

  <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-accent focus:text-white focus:rounded-lg">
    {t("a11y.skipToContent")}
  </a>

  <!-- Page header island (top-right, no InfoButton on share page) -->
  <PageHeaderIsland client:idle />

  <GradientBackground client:idle />

  <div class="min-h-dvh flex flex-col">
    <main id="main-content" class="flex-1 flex flex-col items-center justify-center px-4 sm:px-6 py-12">
      <div class="mb-6 text-center">
        <h1 class="text-3xl sm:text-4xl font-bold tracking-[-0.04em]">
          <a href="/" aria-label="Go to musiccloud home">
            <BrandName client:idle />
          </a>
        </h1>
      </div>
      <ShareLayout client:load config={shareConfig} artistName={isArtist ? displayTitle : artistDisplay} />
    </main>

    <AppFooterIsland client:idle />
  </div>
</BaseLayout>
