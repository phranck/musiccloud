{
  "name": "@musiccloud/backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsup --watch --onSuccess \"node start-dev.mjs\"",
    "build": "tsup",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "backfill:preview-urls": "tsx scripts/backfill-preview-urls.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
