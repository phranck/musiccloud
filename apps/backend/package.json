{
  "name": "@musiccloud/backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsup --watch --onSuccess \"node scripts/copy-swagger-ui-assets.mjs && node scripts/copy-jimp-fonts.mjs && node start-dev.mjs\"",
    "build": "tsup && node scripts/copy-swagger-ui-assets.mjs && node scripts/copy-jimp-fonts.mjs",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "backfill:preview-urls": "tsx scripts/backfill-preview-urls.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/sensible": "^6.0.4",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@musiccloud/shared": "*",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.8.2",
    "fastify-plugin": "^5.1.0",
    "jimp": "^1.6.1",
    "jose": "^6.2.1",
    "nanoid": "^5.1.6",
    "opentype.js": "^1.3.4",
    "pg": "^8.11.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/opentype.js": "^1.3.9",
    "@types/pg": "^8.11.8",
    "execa": "^8.0.1",
    "pretty-format": "^29.7.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  }
}
