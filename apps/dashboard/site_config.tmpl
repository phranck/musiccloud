server {
    listen 80;
    root {{.DocumentRoot}};
    index index.html;

    # SSE endpoint – disable buffering and set a long read timeout
    location /api/admin/events {
        proxy_pass http://backend:4000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 3600s;
        chunked_transfer_encoding on;
    }

    # Realtime website analytics SSE endpoint
    location /api/admin/analytics/website/realtime {
        proxy_pass http://backend:4000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 3600s;
        chunked_transfer_encoding on;
    }

    # Manual DB-IP MMDB update can legitimately take longer than a regular API call.
    location = /api/admin/analytics/website/geoip/update {
        proxy_pass http://backend:4000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        client_max_body_size 1m;
        proxy_request_buffering off;
        proxy_read_timeout 300s;
        proxy_send_timeout 300s;
    }

    # Auth proxy diagnostics: expose upstream timings so client-side probes
    # can distinguish Nginx/backend connect delays from backend handler latency.
    # Keep this scoped to auth endpoints; do not expose upstream internals on
    # every public API response. See architecture/zerops-networking.md.
    location /api/admin/auth/ {
        proxy_pass http://backend:4000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        client_max_body_size 10m;
        proxy_request_buffering off;
        add_header X-MC-Request-Time $request_time always;
        add_header X-MC-Upstream-Addr $upstream_addr always;
        add_header X-MC-Upstream-Status $upstream_status always;
        add_header X-MC-Upstream-Connect-Time $upstream_connect_time always;
        add_header X-MC-Upstream-Header-Time $upstream_header_time always;
        add_header X-MC-Upstream-Response-Time $upstream_response_time always;
    }

    location /api/ {
        proxy_pass http://backend:4000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        client_max_body_size 10m;
        proxy_request_buffering off;
    }

    location / {
        try_files $uri $uri/ /index.html;
    }
}
