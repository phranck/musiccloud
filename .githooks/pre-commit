#!/usr/bin/env bash

# react-doctor hook start
react_doctor_scan_repository() {
  if [ -x "./node_modules/.bin/react-doctor" ]; then
    "./node_modules/.bin/react-doctor" . --verbose --no-score --yes --no-color
    return
  fi

  if command -v react-doctor >/dev/null 2>&1; then
    react-doctor . --verbose --no-score --yes --no-color
    return
  fi

  if command -v pnpm >/dev/null 2>&1; then
    pnpm exec react-doctor . --verbose --no-score --yes --no-color
    return
  fi

  printf '%s\n' "react-doctor: command not found; skipping repository scan."
}

react_doctor_output=$(mktemp "${TMPDIR:-/tmp}/react-doctor-hook.XXXXXX")
if react_doctor_scan_repository > "$react_doctor_output" 2>&1; then
  rm -f "$react_doctor_output"
else
  cat "$react_doctor_output" >&2
  rm -f "$react_doctor_output"
  printf '%s\n' "React Doctor found repository regressions." "Run pnpm doctor to inspect and resolve the findings." >&2
  exit 1
fi
# react-doctor hook end
# Block commits that contain secrets. Requires gitleaks on PATH.
set -euo pipefail

if ! command -v gitleaks >/dev/null 2>&1; then
  echo "⚠  gitleaks not installed. Skipping secret scan."
  echo "   Install: brew install gitleaks"
  exit 0
fi

gitleaks protect --staged --redact --verbose
