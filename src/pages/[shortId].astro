---
/**
 * Short URL Redirect - SSR rendered
 *
 * Resolves a short URL to the full share link page.
 * Also serves OG meta tags for link preview bots before redirecting.
 * Handles both track and album short IDs.
 */
export const prerender = false;

import { AppFooter } from "../components/AppFooter";
import { GradientBackground } from "../components/GradientBackground";
import { PageHeaderIsland } from "../components/PageHeaderIsland";
import { SharePageCard } from "../components/SharePageCard";
import { getLocaleFromCookie } from "../i18n/locales";
import { loadTranslations, makeT } from "../i18n/server";
import BaseLayout from "../layouts/BaseLayout.astro";
import { loadAlbumByShortId, loadByShortId } from "../lib/share-page";
import { buildMetaLine, isValidPlatform, PLATFORM_CONFIG } from "../lib/utils";
import type { ShareContentConfiguration } from "../components/MediaCard";

const { shortId } = Astro.params;

if (!shortId) {
  return Astro.redirect("/");
}

// SSR i18n: read locale from cookie, load translations
const locale = getLocaleFromCookie(Astro.cookies.get("mc:locale")?.value);
const translations = await loadTranslations(locale);
const t = makeT(translations);

// Try loading as track first, then as album
const trackData = await loadByShortId(shortId, Astro.url.origin).catch(() => null);
const albumData = !trackData ? await loadAlbumByShortId(shortId, Astro.url.origin).catch(() => null) : null;

if (!trackData && !albumData) {
  return Astro.redirect("/", 302);
}

const isAlbum = !trackData && !!albumData;
const og = isAlbum ? albumData!.og : trackData!.og;
const links = isAlbum ? albumData!.links : trackData!.links;

// Track-specific
const track = !isAlbum ? trackData!.track : null;
const artistDisplay = isAlbum ? albumData!.artistDisplay : trackData!.artistDisplay;

// Album-specific
const album = isAlbum ? albumData!.album : null;
const albumYear = album?.releaseDate?.slice(0, 4);

const artworkUrl = isAlbum ? album?.artworkUrl : track?.artworkUrl;
const displayTitle = isAlbum ? album!.title : track!.title;

// Pre-compute meta lines using server-side translations
const trackMetaLine = track
  ? buildMetaLine({ durationMs: track.durationMs, isrc: track.isrc, releaseDate: track.releaseDate })
  : null;
const albumMetaLine = isAlbum
  ? [
      album?.totalTracks ? t("results.albumTracks", { count: String(album.totalTracks) }) : null,
      albumYear,
    ]
      .filter(Boolean)
      .join(" \u00B7 ")
  : null;

// Build platform links (filter invalid services)
const platformLinks = links
  .filter((link) => isValidPlatform(link.service))
  .map((link) => ({
    platform: link.service as import("../lib/utils").Platform,
    url: link.url,
  }));

// Build the ShareContentConfiguration (fully JSON-serializable, passed to React island)
const shareConfig: ShareContentConfiguration = {
  type: "share",
  title: displayTitle,
  artist: artistDisplay,
  artworkUrl: artworkUrl ?? "",
  isExplicit: !isAlbum && track?.isExplicit ? true : undefined,
  metaLine: isAlbum ? albumMetaLine || undefined : trackMetaLine || undefined,
  platforms: platformLinks,
  platformsLabel: t(isAlbum ? "results.openAlbumOn" : "results.listenOn"),
};
---

<BaseLayout
  title={og.pageTitle}
  canonicalUrl={og.ogUrl}
  preloadImage={artworkUrl ?? undefined}
  lang={locale}
>
  <Fragment slot="head">
    <!-- OpenGraph Tags (critical for link previews) -->
    <meta property="og:type" content={isAlbum ? "music.album" : "music.song"} />
    <meta property="og:title" content={og.ogTitle} />
    <meta property="og:description" content={og.ogDescription} />
    <meta property="og:image" content={og.ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${displayTitle} by ${artistDisplay}`} />
    <meta property="og:url" content={og.ogUrl} />
    <meta property="og:site_name" content="musiccloud" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content={og.twitterCard} />
    <meta name="twitter:title" content={og.ogTitle} />
    <meta name="twitter:description" content={og.ogDescription} />
    <meta name="twitter:image" content={og.ogImageUrl} />
  </Fragment>

  <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-accent focus:text-white focus:rounded-lg">
    {t("a11y.skipToContent")}
  </a>

  <!-- Page header island (top-right, no InfoButton on share page) -->
  <PageHeaderIsland client:load />

  <GradientBackground client:load />

  <div class="min-h-dvh flex flex-col">
    <main id="main-content" class="flex-1 flex flex-col items-center justify-center px-4 sm:px-6 py-12">
      <SharePageCard client:load config={shareConfig} />
    </main>

    <AppFooter />
  </div>
</BaseLayout>
