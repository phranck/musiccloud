---
/**
 * Short URL Redirect - SSR rendered
 *
 * Resolves a short URL to the full share link page.
 * Also serves OG meta tags for link preview bots before redirecting.
 */
export const prerender = false;

import BaseLayout from "../layouts/BaseLayout.astro";
import { loadByShortId } from "../lib/share-page";
import { PLATFORM_CONFIG, isValidPlatform, formatDuration, formatYear, type Platform } from "../lib/utils";
import { PlatformIcon } from "../components/PlatformIcon";
import { GradientBackground } from "../components/GradientBackground";

const { shortId } = Astro.params;

if (!shortId) {
  return Astro.redirect("/");
}

const data = await loadByShortId(shortId, Astro.url.origin);

if (!data) {
  return Astro.redirect("/", 302);
}

const { track, artistDisplay, links, og } = data;

const metaItems = [
  track.durationMs ? formatDuration(track.durationMs) : null,
  track.isrc,
  track.releaseDate ? formatYear(track.releaseDate) : null,
].filter(Boolean);
const metaLine = metaItems.join(" \u00B7 ");
---

<BaseLayout
  title={og.pageTitle}
  canonicalUrl={og.ogUrl}
  preloadImage={track.artworkUrl}
>
  <Fragment slot="head">
    <!-- OpenGraph Tags (critical for link previews) -->
    <meta property="og:type" content="music.song" />
    <meta property="og:title" content={og.ogTitle} />
    <meta property="og:description" content={og.ogDescription} />
    <meta property="og:image" content={og.ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content={og.ogUrl} />
    <meta property="og:site_name" content="musiccloud" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content={og.twitterCard} />
    <meta name="twitter:title" content={og.ogTitle} />
    <meta name="twitter:description" content={og.ogDescription} />
    <meta name="twitter:image" content={og.ogImageUrl} />
  </Fragment>

  <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-accent focus:text-white focus:rounded-lg">Skip to content</a>

  <GradientBackground client:load />

  <div class="min-h-dvh flex flex-col">
  <main id="main-content" class="flex-1 flex flex-col items-center justify-center px-4 sm:px-6 py-12">
    {/* Album Art */}
    {track.artworkUrl && (
      <img
        src={track.artworkUrl}
        alt={`${track.title} by ${artistDisplay}`}
        class="mb-6 w-full max-w-[280px] sm:max-w-sm aspect-square rounded-xl sm:rounded-2xl shadow-2xl object-cover bg-surface-elevated"
        width="384"
        height="384"
        onerror="this.style.display='none'"
      />
    )}

    {/* Song Info */}
    <h1 class="mb-1 text-xl sm:text-2xl md:text-3xl font-bold tracking-[-0.02em] text-center px-4">{track.title}</h1>
    <p class="text-lg text-text-secondary text-center mt-1">{artistDisplay}</p>
    {(track.isExplicit || metaLine) && (
      <p class="text-sm text-text-muted/60 text-center mt-2 mb-8 font-mono tracking-wide inline-flex items-center justify-center gap-1.5">
        {track.isExplicit && (
          <span class="inline-flex items-center justify-center w-[18px] h-[18px] rounded-[3px] bg-text-muted/20 text-text-muted text-[10px] font-bold leading-none flex-shrink-0" title="Explicit" aria-label="Explicit content">E</span>
        )}
        <span>{metaLine}</span>
      </p>
    )}
    {!track.isExplicit && !metaLine && <div class="mb-8" />}

    {/* Platform Buttons */}
    <div class="w-full max-w-sm space-y-3">
      {[...links].sort((a, b) => (PLATFORM_CONFIG[a.service as Platform]?.label ?? a.service).localeCompare(PLATFORM_CONFIG[b.service as Platform]?.label ?? b.service)).map((link) => {
        if (!isValidPlatform(link.service)) return null;
        const platform = link.service;
        const config = PLATFORM_CONFIG[platform];
        const label = config.label;
        return (
          <a
            href={link.url}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-3 px-4 sm:px-5 py-3 rounded-xl transition-all duration-150 min-h-[52px] w-full bg-white/[0.06] border border-white/[0.10] hover:bg-white/[0.10] hover:scale-[1.03] hover:shadow-[0_0_16px_var(--platform-color)] focus-visible:bg-white/[0.10] focus-visible:scale-[1.03] focus-visible:shadow-[0_0_16px_var(--platform-color)] active:scale-[0.97]"
            style={`--platform-color: ${config.color}60`}
            aria-label={`Open ${track.title} on ${label} (opens in new window)`}
          >
            <PlatformIcon client:load platform={platform} className="w-7 h-7 flex-shrink-0" colored={true} />
            <span class="font-medium text-base text-text-primary tracking-[-0.01em] flex-1">
              Listen on {label}
            </span>
            <svg
              class="w-4 h-4 text-text-muted flex-shrink-0"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
              />
            </svg>
          </a>
        );
      })}
    </div>
  </main>

  <footer class="flex items-center justify-center px-4 sm:px-6 py-3 text-xs text-text-muted" style="padding-bottom: max(1rem, env(safe-area-inset-bottom))">
    <span>
      powered by
      <a href="/" class="text-accent hover:text-accent-hover transition-colors duration-150 ml-1 font-medium">
        musiccloud
      </a>
    </span>
  </footer>
  </div>
</BaseLayout>
