---
/**
 * Share Link Page - SSR rendered
 *
 * Shows a track with cross-platform links. Must work without JavaScript
 * for OG crawler bots (all meta tags in initial HTML).
 */
export const prerender = false;

import { loadByTrackId } from "../../lib/share-page";
import { PLATFORM_CONFIG, isValidPlatform, type Platform } from "../../lib/utils";
import "../../styles/global.css";

const { id } = Astro.params;

if (!id) {
  return Astro.redirect("/");
}

const data = await loadByTrackId(id);

if (!data) {
  return Astro.redirect("/", 302);
}

const { track, artists, artistDisplay, links, og } = data;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{og.pageTitle}</title>

    <!-- OpenGraph Tags -->
    <meta property="og:type" content="music.song" />
    <meta property="og:title" content={og.ogTitle} />
    <meta property="og:description" content={og.ogDescription} />
    <meta property="og:image" content={og.ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content={og.ogUrl} />
    <meta property="og:site_name" content="music.cloud" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content={og.twitterCard} />
    <meta name="twitter:title" content={og.ogTitle} />
    <meta name="twitter:description" content={og.ogDescription} />
    <meta name="twitter:image" content={og.ogImageUrl} />

    <!-- Music Metadata -->
    <meta property="music:musician" content={artistDisplay} />
    {track.albumName && <meta property="music:album" content={track.albumName} />}

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "MusicRecording",
      "name": track.title,
      "byArtist": artists.map((a) => ({ "@type": "MusicGroup", "name": a })),
      "inAlbum": track.albumName ? { "@type": "MusicAlbum", "name": track.albumName } : undefined,
      "image": track.artworkUrl,
      "url": og.ogUrl,
    })} />

    <link rel="canonical" href={og.ogUrl} />

    {track.artworkUrl && <link rel="preload" as="image" href={track.artworkUrl} />}
  </head>
  <body class="bg-background text-text-primary antialiased">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-accent focus:text-white focus:rounded-lg">Skip to content</a>
    <main id="main-content" class="mx-auto max-w-md px-4 py-12 text-center">
      {track.artworkUrl && (
        <img
          src={track.artworkUrl}
          alt={`${track.title} by ${artistDisplay}`}
          class="mx-auto mb-6 h-56 w-56 md:h-64 md:w-64 rounded-2xl shadow-2xl bg-surface-elevated"
          width="256"
          height="256"
          onerror="this.style.display='none'"
        />
      )}

      <h1 class="mb-1 text-3xl font-bold tracking-[-0.02em]">{track.title}</h1>
      <p class="mb-8 text-lg text-text-secondary">{artistDisplay}</p>

      <div class="space-y-3">
        {links.map((link) => {
          if (!isValidPlatform(link.service)) return null;
          const platform = link.service;
          const config = PLATFORM_CONFIG[platform];
          const label = config.label;
          return (
            <a
              href={link.url}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-center gap-3 rounded-xl bg-surface-elevated/60 px-5 py-4 font-medium tracking-[-0.01em] backdrop-blur border border-white/[0.06] transition-all duration-150 hover:bg-surface-elevated"
            >
              Listen on {label}
            </a>
          );
        })}
      </div>

      <p class="mt-12 text-sm text-text-muted">
        powered by
        <a href="/" class="text-accent hover:underline ml-1">
          music.cloud
        </a>
      </p>
    </main>
  </body>
</html>
