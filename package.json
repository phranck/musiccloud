{
  "name": "musiccloud",
  "private": true,
  "packageManager": "pnpm@10.33.1",
  "scripts": {
    "dev": "pnpm --filter @musiccloud/frontend dev",
    "dev:backend": "pnpm --filter @musiccloud/backend dev",
    "dev:dashboard": "pnpm --filter @musiccloud/dashboard dev",
    "dev:shared": "pnpm --filter @musiccloud/shared dev",
    "dev:all": "concurrently -k -n shared,backend,frontend,dashboard -c gray,magenta,cyan,yellow \"pnpm dev:shared\" \"pnpm dev:backend\" \"pnpm dev\" \"pnpm dev:dashboard\"",
    "dev:stop": "pkill -f 'concurrently -k -n shared,backend,frontend,dashboard' || true",
    "dev:restart": "pnpm dev:stop && sleep 1 && pnpm dev:all",
    "dev:status": "node scripts/dev-status.mjs",
    "build": "pnpm --filter @musiccloud/shared build && pnpm -r --if-present build",
    "test": "pnpm -r --if-present test",
    "test:run": "pnpm -r --if-present test:run",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "audit:content-i18n": "node scripts/audit-content-i18n.mjs",
    "db:generate": "drizzle-kit generate --config=drizzle.config.postgres.ts",
    "db:migrate": "node scripts/migrate.mjs",
    "db:studio": "drizzle-kit studio --config=drizzle.config.postgres.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "concurrently": "^9.1.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^1.6.1"
  },
  "optionalDependencies": {
    "@rolldown/binding-linux-x64-musl": "1.0.0-rc.9",
    "@rollup/rollup-linux-x64-musl": "4.57.1",
    "@tailwindcss/oxide-linux-x64-musl": "4.2.1",
    "lightningcss-linux-x64-musl": "1.31.1"
  }
}
