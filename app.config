# app.config — defines which apps ./app manages.
# Parallel arrays: APP_NAMES[i], APP_PORTS[i], APP_CMDS[i] belong together.
# APP_PORTS=- (or empty) means "no port"; URL column will show as dash.
# Optional APP_HOSTS[i] overrides default "localhost".
# APP_HEALTH_PATHS[i] is an absolute HTTP readiness path for every app with a
# port. Use - only for process-only watchers. A successful probe is necessary
# but not sufficient: ./app also verifies that the listener belongs to the
# managed process tree.

APP_NAMES=(shared backend frontend developer dashboard)
APP_PORTS=(- 4000 3001 3002 4500)
APP_HEALTH_PATHS=(- /health/backend / / /)
APP_CMDS=(
  "pnpm dev:shared"
  "pnpm dev:backend"
  "pnpm dev"
  "pnpm dev:developer"
  "pnpm dev:dashboard"
)
